# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_NAME=SaaS CRM

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=saas_crm
DATABASE_URL="postgresql://user:password@localhost:5432/saas_crm?schema=public"

# Redis (for sessions, caching, rate limiting)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,csv

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@example.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Storage Quota (in bytes)
DEFAULT_FILE_STORAGE_QUOTA=5368709120
DEFAULT_EMAIL_STORAGE_QUOTA=1073741824

# Google Maps APIs
GOOGLE_GEOCODING_API_KEY=your-google-geocoding-api-key
GOOGLE_STATIC_MAPS_API_KEY=your-google-static-maps-api-key
GOOGLE_MAPS_JS_API_KEY=your-google-maps-js-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# AI Service (roof estimator microservice)
AI_SERVICE_URL=http://localhost:8001

# EagleView
EAGLEVIEW_CLIENT_ID=your-eagleview-client-id
EAGLEVIEW_CLIENT_SECRET=your-eagleview-client-secret
EAGLEVIEW_BASE_URL=https://sandbox.apis.eagleview.com
EAGLEVIEW_TOKEN_URL=https://apicenter.eagleview.com/oauth2/v1/token
