// ============================================================================
// COMMUNICATION - EMAIL (LETTER BOX)
// ============================================================================

model CommunicationLog {
  id        String                 @id @default(uuid())
  tenantId  String
  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId    String?
  lead      Lead?                  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  type      CommunicationType
  direction CommunicationDirection
  subject   String?
  content   String
  to        String
  createdAt DateTime               @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, leadId])
  @@index([tenantId, type])
}

model EmailLabel {
  id              String      @id @default(uuid())
  name            String
  color           String?
  
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime    @default(now())
  
  emails          EmailLabelAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Email {
  id              String        @id @default(uuid())
  
  // Email metadata
  messageId       String?       // For external email systems
  threadId        String?       // For conversation threading
  
  // Sender/Recipients
  fromAddress     String
  fromName        String?
  toAddresses     Json          // Array of {email, name}
  ccAddresses     Json?         // Array of {email, name}
  bccAddresses    Json?         // Array of {email, name}
  replyTo         String?
  
  // Content
  subject         String
  bodyText        String?       @db.Text
  bodyHtml        String?       @db.Text
  
  // Status & Folder
  status          EmailStatus   @default(RECEIVED)
  folder          EmailFolder   @default(INBOX)
  
  // Flags
  isRead          Boolean       @default(false)
  isStarred       Boolean       @default(false)
  hasAttachments  Boolean       @default(false)
  
  // Size (for quota)
  size            BigInt        @default(0)
  
  // Sent by (if outgoing)
  sentById        String?
  sentBy          Employee?     @relation("SentByEmployee", fields: [sentById], references: [id], onDelete: SetNull)

  // Mailbox owner (personal letter box)
  mailboxOwnerUserId String?
  mailboxOwnerUser   User?      @relation("MailboxOwnerUser", fields: [mailboxOwnerUserId], references: [id], onDelete: SetNull)
  
  // Entity links (optional — link emails to CRM entities)
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  contactId       String?
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  
  leadId          String?
  lead            Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  quoteId         String?
  quote           Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  // Timestamps
  sentAt          DateTime?
  receivedAt      DateTime?
  
  // Tenant relation
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?     // Soft delete for trash
  
  // Relations
  labels          EmailLabelAssignment[]
  attachments     EmailAttachment[]

  @@index([tenantId])
  @@index([tenantId, mailboxOwnerUserId])
  @@index([folder])
  @@index([status])
  @@index([sentById])
  @@index([messageId])
  @@index([threadId])
  @@index([isRead])
  @@index([deletedAt])
  @@index([clientId])
  @@index([contactId])
  @@index([leadId])
  @@index([quoteId])
  @@index([projectId])
  @@unique([tenantId, mailboxOwnerUserId, messageId])
}

model EmailLabelAssignment {
  id        String      @id @default(uuid())
  
  emailId   String
  email     Email       @relation(fields: [emailId], references: [id], onDelete: Cascade)
  
  labelId   String
  label     EmailLabel  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([emailId, labelId])
  @@index([emailId])
  @@index([labelId])
}

model EmailAttachment {
  id              String    @id @default(uuid())
  
  emailId         String
  email           Email     @relation(fields: [emailId], references: [id], onDelete: Cascade)
  
  filename        String
  mimeType        String
  size            BigInt
  path            String

  @@index([emailId])
}

// ============================================================================
// COMMUNICATION - CHAT
// ============================================================================

model ChatRoom {
  id              String      @id @default(uuid())
  
  // Room Info
  name            String?     // Null for 1-to-1 chats
  isGroup         Boolean     @default(false)
  
  // Last message for quick access
  lastMessageAt   DateTime?
  lastMessagePreview String?
  
  // Tenant relation
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  participants    ChatParticipant[]
  messages        ChatMessage[]

  @@index([tenantId])
  @@index([lastMessageAt])
}

model ChatParticipant {
  id              String      @id @default(uuid())
  
  roomId          String
  room            ChatRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  // Role in group chat
  role            String      @default("member") // admin, member
  
  // Read tracking
  lastReadAt      DateTime?
  unreadCount     Int         @default(0)
  
  // Timestamps
  joinedAt        DateTime    @default(now())
  leftAt          DateTime?

  @@unique([roomId, employeeId])
  @@index([roomId])
  @@index([employeeId])
}

model ChatMessage {
  id              String      @id @default(uuid())
  
  roomId          String
  room            ChatRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  // Sender (null for system messages)
  senderId        String?
  
  // Content
  content         String      @db.Text
  messageType     String      @default("text") // text, image, file, system
  
  // Attachments (stored as JSON for flexibility)
  attachments     Json?
  
  // Status
  isEdited        Boolean     @default(false)
  editedAt        DateTime?
  
  // Timestamps
  createdAt       DateTime    @default(now())
  deletedAt       DateTime?   // Soft delete

  @@index([roomId])
  @@index([senderId])
  @@index([createdAt])
}

// ============================================================================
// NOTIFICATIONS MODULE (CONTINUED)
// ============================================================================

model Notification {
  id              String            @id @default(uuid())
  
  // Content
  title           String
  message         String            @db.Text
  type            NotificationType  @default(INFO)
  
  // Action (optional link)
  actionUrl       String?
  actionLabel     String?
  
  // Metadata (flexible JSON for additional data)
  metadata        Json?
  
  // Target user
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Read status
  isRead          Boolean           @default(false)
  readAt          DateTime?
  
  // Tenant relation
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime          @default(now())
  expiresAt       DateTime?         // Optional expiration

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
}

// ============================================================================
// AUDIT LOGS MODULE
// ============================================================================

model AuditLog {
  id              String        @id @default(uuid())
  
  // Action details
  action          AuditAction
  module          String        // e.g., "auth", "leads", "invoices"
  description     String
  
  // Entity reference
  entityType      String?       // e.g., "Lead", "Invoice"
  entityId        String?
  
  // Changes (for update actions)
  oldValues       Json?
  newValues       Json?
  
  // Request info
  ipAddress       String?
  userAgent       String?
  requestMethod   String?
  requestPath     String?
  
  // User who performed action
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamp
  createdAt       DateTime      @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================================================
// TAGS (SHARED ACROSS MODULES)
// ============================================================================

model Tag {
  id              String      @id @default(uuid())
  name            String
  color           String?     // Hex color for UI
  
  // Tenant relation
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  leads           LeadTag[]
  tasks           TaskTag[]
  files           FileTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ============================================================================
// SETTINGS (TENANT & USER PREFERENCES)
// ============================================================================

model TenantSettings {
  id              String      @id @default(uuid())
  
  tenantId        String      @unique
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // General Settings
  timezone        String      @default("UTC")
  dateFormat      String      @default("YYYY-MM-DD")
  timeFormat      String      @default("HH:mm")
  currency        Currency    @default(USD)
  language        String      @default("en")
  
  // Business Settings
  fiscalYearStart Int         @default(1) // Month (1-12)
  
  // Invoice Settings
  invoicePrefix   String      @default("INV-")
  invoiceNextNumber Int       @default(1)
  invoiceTerms    String?     @db.Text
  invoiceNotes    String?     @db.Text
  
  // Email Settings
  emailSignature  String?     @db.Text
  
  // Notification Preferences (JSON)
  notificationSettings Json   @default("{}")
  
  // Integration Flags (for future integrations)
  integrations    Json        @default("{}")
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model UserPreferences {
  id              String      @id @default(uuid())
  
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // UI Preferences
  theme           String      @default("light") // light, dark, system
  sidebarCollapsed Boolean    @default(false)
  language        String      @default("en")
  
  // Notification Preferences
  emailNotifications Boolean  @default(true)
  pushNotifications Boolean   @default(true)
  notificationSound Boolean   @default(true)
  
  // Dashboard Preferences (JSON for widget layout)
  dashboardLayout Json        @default("{}")
  
  // Table Preferences (columns, sorting, etc.)
  tablePreferences Json       @default("{}")
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ============================================================================
// ROOF ESTIMATOR MODULE
// ============================================================================

model RoofEstimate {
  id                  String    @id @default(uuid())

  // Address & Geo
  address             String
  latitude            Float
  longitude           Float
  satelliteImageUrl   String?
  placeId             String?             // Google place_id for precise re-lookup
  locationType        String?             // ROOFTOP, RANGE_INTERPOLATED, GEOMETRIC_CENTER, APPROXIMATE
  parcelPolygon       Json?               // ATTOM parcel boundary polygon coordinates
  attomPropertyId     String?             // ATTOM property identifier

  // AI Results
  roofAreaSqft        Float
  confidence          Float     @default(0)
  processingTimeSec   Float     @default(0)
  aiModel             String    @default("yolov8n-seg-cpu")

  // Roof Characteristics
  pitch               String?             // e.g. "6/12", "8/12"
  pitchDegrees        Float?              // calculated degrees from pitch ratio
  stories             Int?      @default(1)
  roofType            String?             // gable, hip, flat, mansard, gambrel, shed
  layers              Int?      @default(1)

  // Roof Measurements (linear ft)
  ridgeLengthFt       Float?
  hipLengthFt         Float?
  valleyLengthFt      Float?
  eaveLengthFt        Float?
  rakeLengthFt        Float?
  trueSurfaceAreaSqft Float?              // pitch-adjusted area

  // Measurement Source
  measurementSource   String?             // 'ai_satellite', 'ai_photo', 'eagleview', 'manual'

  // Pricing
  pricePerSqft        Float     @default(0)
  manualAdjustment    Float     @default(0) // percentage adjustment
  totalEstimate       Float     @default(0)

  // Flags
  snowMode            Boolean   @default(false)
  tearOffRequired     Boolean   @default(false)
  notes               String?   @db.Text
  pdfUrl              String?

  // AI Damage Detection
  damageReport        Json?               // { areas: [{type, severity, bbox, confidence}] }
  photoUrls           Json?               // array of uploaded photo URLs

  // Public access (for e-sign / client view)
  publicToken         String?   @unique

  // AI Segmentation Results
  roofPolygon         Json?               // GeoJSON polygon from segmentation mask
  roofPlanes          Json?               // detected roof planes [{area, pitch, azimuth, vertices}]
  detectedLines       Json?               // Hough/edge-detected structural lines
  solarValidated      Boolean   @default(false)
  correctionFactor    Float?              // Solar API correction factor applied
  confidenceScore     Float?              // composite 0-1 confidence
  flaggedForReview    Boolean   @default(false) // confidence < 0.75

  // Wizard Workflow
  status              String    @default("draft")   // draft, completed, sent
  currentStep         Int       @default(1)         // wizard step 1-6
  wastePercent        Float?    @default(10)        // waste % for materials

  // Step 2: Material Pricing
  shingleType         String?
  shinglePricePerSq   Float?
  underlaymentCost    Float?
  iceWaterShieldCost  Float?
  ridgeCapCost        Float?
  starterStripCost    Float?
  flashingCostWizard  Float?
  ventCostWizard      Float?
  nailsAccessoriesCost Float?
  totalMaterialCost   Float?

  // Step 3: Labor
  laborCostPerSquare  Float?
  numberOfLaborers    Int?
  daysRequired        Int?
  laborRatePerWorker  Float?
  totalLaborCost      Float?

  // Step 4: Equipment / Extras
  dumpsterCost        Float?
  permitCost          Float?
  deliveryFee         Float?
  equipmentRentalCost Float?
  disposalFee         Float?
  totalEquipmentCost  Float?

  // Step 5: Profit & Overhead
  overheadPercent     Float?
  profitMarginPercent Float?
  taxPercent          Float?

  // Step 6: Final calculations
  overheadAmount      Float?
  profitAmount        Float?
  taxAmount           Float?
  finalEstimatePrice  Float?

  // Relations
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId            String?
  client              Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  leadId              String?
  lead                Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  createdBy           String

  // Timestamps
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Back-relations
  quotes              Quote[]
  takeoffs            RoofTakeoff[]
  solarData           SolarRoofData[]
  proposals           Proposal[]

  @@index([tenantId])
  @@index([clientId])
  @@index([leadId])
  @@index([createdAt])
}

model RoofEstimateSettings {
  id                String    @id @default(uuid())

  tenantId          String    @unique
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  defaultPricePerSqft Float   @default(5.50)
  currency          String    @default("CAD")
  snowModeDefault   Boolean   @default(true)
  companyName       String?   // For PDF branding
  companyLogo       String?
  companyPhone      String?
  companyEmail      String?
  companyAddress    String?
  pdfFooterText     String?   @db.Text

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ── Supplier Pricing Database ─────────────────────────────────────────────

model RoofMaterial {
  id              String    @id @default(uuid())
  name            String                    // "OC Duration Shingles"
  category        String                    // shingles, underlayment, starter, cap, drip_edge, flashing, ice_shield, vent, nails
  unit            String                    // "bundle", "roll", "linear_ft", "each", "box"
  coveragePerUnit Float                     // e.g. 33.3 sqft per bundle
  defaultPrice    Float                     // unit price
  supplier        String?
  sku             String?
  isActive        Boolean   @default(true)

  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  takeoffItems    RoofTakeoffItem[]

  @@unique([tenantId, name, category])
  @@index([tenantId])
  @@index([category])
}

// ── Material Takeoff per Estimate ─────────────────────────────────────────

model RoofTakeoff {
  id                String    @id @default(uuid())

  estimateId        String
  estimate          RoofEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  scenarioName      String    @default("default")   // e.g. "Asphalt Standard", "Metal Premium"
  materialType      String                           // "asphalt", "metal", "tile", "tpo", "cedar"

  // Waste & Area
  wasteFactor       Float     @default(10)           // percentage
  adjustedAreaSqft  Float?                           // after waste

  // Cost Breakdown
  laborRatePerSqft  Float?
  laborHours        Float?
  laborCost         Float?    @default(0)
  materialCost      Float?    @default(0)
  accessoryCost     Float?    @default(0)
  tearOffCost       Float?    @default(0)
  subtotal          Float?    @default(0)

  // Markup & Profit
  markupPercent     Float?    @default(20)
  profit            Float?    @default(0)
  totalPrice        Float?    @default(0)

  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  items             RoofTakeoffItem[]

  @@index([estimateId])
  @@index([tenantId])
}

model RoofTakeoffItem {
  id              String    @id @default(uuid())

  takeoffId       String
  takeoff         RoofTakeoff @relation(fields: [takeoffId], references: [id], onDelete: Cascade)

  materialId      String?
  material        RoofMaterial? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  description     String
  category        String                // shingles, underlayment, starter, cap, drip_edge, ice_shield, flashing, vent, nails, boot, snow_guard
  quantity        Float
  unit            String
  unitPrice       Float
  wasteFactor     Float     @default(10)
  wasteQuantity   Float                 // quantity added for waste
  totalQuantity   Float                 // quantity + wasteQuantity
  totalPrice      Float
  sortOrder       Int       @default(0)

  @@index([takeoffId])
  @@index([materialId])
}

// ── Labor Rates ───────────────────────────────────────────────────────────

model RoofLaborRate {
  id              String    @id @default(uuid())
  description     String                    // "Standard Install", "Steep Pitch Surcharge", "2nd Story Surcharge"
  rateType        String                    // "per_sqft", "per_hour", "flat"
  rate            Float
  condition       String?                   // e.g. "pitch > 8/12", "stories >= 2", "tear_off"
  isActive        Boolean   @default(true)

  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
}

// ============================================================================
// WALLET MODULE
// ============================================================================

model Wallet {
  id              String    @id @default(uuid())

  tenantId        String    @unique
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  balance         Float     @default(500)    // Starting test balance ($500)
  currency        String    @default("CAD")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    WalletTransaction[]

  @@index([tenantId])
}

model WalletTransaction {
  id              String    @id @default(uuid())

  walletId        String
  wallet          Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type            String                    // "credit" | "debit"
  amount          Float
  description     String
  balanceAfter    Float

  referenceType   String?                   // "estimate" | "manual" | "topup"
  referenceId     String?                   // estimate ID if applicable

  createdBy       String?

  createdAt       DateTime  @default(now())

  @@index([walletId])
  @@index([createdAt])
}

// ============================================================================
// QUOTES / PROPOSALS MODULE
// ============================================================================

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  SIGNED
  REJECTED
  EXPIRED
}

model Quote {
  id                String          @id @default(uuid())
  
  // Quote Number (auto-generated like invoices)
  quoteNumber       String
  
  // Status
  status            QuoteStatus     @default(DRAFT)
  
  // Client (optional — may be lead-only)
  clientId          String?
  client            Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  // Lead (optional — for pre-client quotes)
  leadId            String?
  lead              Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  // Dates
  issueDate         DateTime        @default(now())
  validUntil        DateTime
  
  // Currency
  currency          String          @default("CAD")
  
  // Amounts
  subtotal          Decimal         @db.Decimal(15, 2)
  taxRate           Decimal?        @db.Decimal(5, 2)
  taxAmount         Decimal         @default(0) @db.Decimal(15, 2)
  discountAmount    Decimal         @default(0) @db.Decimal(15, 2)
  total             Decimal         @db.Decimal(15, 2)
  
  // Notes & Terms
  notes             String?         @db.Text
  terms             String?         @db.Text
  
  // Stage 3: Payment & Warranty
  paymentScheduleType String?                 // "full_upfront", "50_50", "milestone", "net_30"
  warrantySelected    String?                 // "standard", "extended", "premium"
  validDays           Int             @default(30)
  
  // Source context (which meeting triggered this)
  sourceEventId     String?         // Calendar event that triggered quote creation
  
  // Linked roof estimate (for PDF attachment on send)
  roofEstimateId    String?
  roofEstimate      RoofEstimate?   @relation(fields: [roofEstimateId], references: [id], onDelete: SetNull)
  
  // Created by
  createdById       String?
  createdBy         Employee?       @relation("CreatedByEmployee", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Public access token for email link
  publicToken       String?         @unique
  isContract        Boolean         @default(false)
  contractVersion   Int             @default(0)
  viewCount         Int             @default(0)
  firstViewedAt     DateTime?
  lastViewedAt      DateTime?
  signedAt          DateTime?
  signedBy          String?
  signatureType     String?
  signatureData     String?         @db.Text
  signerIpAddress   String?
  signerUserAgent   String?         @db.Text
  contractSnapshot  Json?
  auditTrail        Json?
  signedPdfFileId   String?
  rejectedAt        DateTime?

  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  sentAt            DateTime?
  acceptedAt        DateTime?
  
  // Relations
  items             QuoteItem[]
  projects          Project[]
  contracts         Contract[]
  invoices          Invoice[]
  files             File[]
  emails            Email[]
  proposals         Proposal[]

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
  @@index([status])
  @@index([clientId])
  @@index([leadId])
  @@index([roofEstimateId])
  @@index([validUntil])
}

model QuoteItem {
  id            String    @id @default(uuid())
  
  description   String
  quantity      Decimal   @default(1) @db.Decimal(10, 2)
  unitPrice     Decimal   @db.Decimal(15, 2)
  total         Decimal   @db.Decimal(15, 2)
  
  // Sort order
  sortOrder     Int       @default(0)
  
  // Parent Quote
  quoteId       String
  quote         Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

// ============================================================================
// PROPOSALS MODULE
// ============================================================================

enum ProposalStatus {
  DRAFT
  GENERATED
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

model Proposal {
  id                    String          @id @default(uuid())
  proposalNumber        String                          // PR-YYYY-0001

  // Status
  status                ProposalStatus  @default(DRAFT)

  // Links
  leadId                String
  lead                  Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  quoteId               String
  quote                 Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  roofEstimateId        String?
  roofEstimate          RoofEstimate?   @relation(fields: [roofEstimateId], references: [id], onDelete: SetNull)

  // Content
  customMessageToClient String?         @db.Text
  coverPageHtml         String?         @db.Text
  scopeOfWork           String?         @db.Text
  termsAndConditions    String?         @db.Text

  // PDF
  pdfUrl                String?
  pdfGeneratedAt        DateTime?

  // E-Signature
  publicToken           String?         @unique
  signedAt              DateTime?
  signedByName          String?
  signatureData         String?         @db.Text    // base64 signature image
  initials              String?                     // Stage 5: signer initials
  signerIpAddress       String?                     // Stage 5: IP address at signing

  // Stage 4: View Tracking & Delivery
  lastViewedAt          DateTime?
  viewCount             Int             @default(0)
  deliveryMethod        String?                         // "email", "sms", "email_sms"

  // Tenant
  tenantId              String
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Created by
  createdById           String?
  createdBy             Employee?       @relation("ProposalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  sentAt                DateTime?

  @@unique([tenantId, proposalNumber])
  @@index([tenantId])
  @@index([leadId])
  @@index([quoteId])
  @@index([status])
}

// ============================================================================
// SIGNED CONTRACTS MODULE (Stage 5)
// ============================================================================

model SignedContract {
  id              String   @id @default(uuid())

  // References
  proposalId      String
  leadId          String
  clientId        String?

  // E-Signature Data
  fullLegalName   String
  signatureImage  String   @db.Text
  initials        String
  dateSigned      DateTime
  ipAddress       String

  // Signed PDF
  signedPdfUrl    String?

  // Tenant
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([proposalId])
  @@index([tenantId])
}

// ============================================================================
// CONTRACTS MODULE
// ============================================================================

enum ContractStatus {
  DRAFT
  SENT
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

model Contract {
  id                String          @id @default(uuid())
  
  // Contract Number (auto-generated like invoices)
  contractNumber    String
  title             String
  description       String?         @db.Text
  
  // Status
  status            ContractStatus  @default(DRAFT)
  
  // Linked entities
  clientId          String
  client            Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  quoteId           String?
  quote             Quote?          @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  
  projectId         String?
  project           Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  // Financial
  value             Decimal         @db.Decimal(15, 2)
  currency          String          @default("CAD")
  
  // Dates
  startDate         DateTime
  endDate           DateTime
  signedAt          DateTime?
  
  // Terms & Content
  terms             String?         @db.Text
  notes             String?         @db.Text
  
  // Created by
  createdById       String?
  createdBy         Employee?       @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([tenantId, contractNumber])
  @@index([tenantId])
  @@index([status])
  @@index([clientId])
  @@index([quoteId])
  @@index([projectId])
  @@index([startDate])
  @@index([endDate])
}

// ============================================================================
// NEARMAP ROOF DATA
// ============================================================================

model RoofData {
  id               String   @id @default(uuid())

  // Source & Location
  source           String   @default("nearmap")
  address          String?
  latitude         Float?
  longitude        Float?

  // AI Extraction Results
  buildingOutline  Json?              // GeoJSON polygon of building footprint
  roofOutline      Json?              // GeoJSON polygon of roof outline
  propertyInsights Json?              // Structured AI insights (area, material, condition)
  areaSqFt         Float?             // Total roof area in sq ft

  // Raw API Response (audit/debugging)
  rawApiResponse   Json?

  // Relations
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([clientId])
  @@index([tenantId])
}

model SolarRoofData {
  id                String          @id @default(uuid())

  // Location
  latitude          Float
  longitude         Float
  address           String?

  // Solar API Extracted Data
  roofAreaSqft      Float?          // converted from roofAreaMeters2
  roofAreaMeters2   Float?          // raw from API
  roofSegments      Json?           // roofSegmentStats array from API
  pitchDegrees      Float?          // primary pitch
  azimuthDegrees    Float?          // primary azimuth
  maxSunshineHours  Float?
  carbonOffset      Float?          // annual kg CO2 offset
  panelCapacity     Int?            // max solar panel count

  // Raw API Response (audit/debugging)
  rawResponse       Json?

  // Relations
  estimateId        String?
  estimate          RoofEstimate?   @relation(fields: [estimateId], references: [id], onDelete: SetNull)

  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([estimateId])
  @@index([tenantId])
  @@index([latitude, longitude])
}

// ============================================================================
// SUPER ADMIN MODULE
// ============================================================================

model SuperAdmin {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              String   @default("SUPER_ADMIN")
  isActive          Boolean  @default(true)
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([email])
}

model Subscription {
  id              String    @id @default(uuid())
  tenantId        String    @unique
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planType        String    @default("TRIAL")
  billingCycle    String    @default("MONTHLY")
  status          String    @default("TRIAL")
  startDate       DateTime  @default(now())
  nextBillingDate DateTime?
  cancelledAt     DateTime?
  monthlyRate     Decimal   @default(0) @db.Decimal(10,2)
  totalPaid       Decimal   @default(0) @db.Decimal(10,2)
  failedPayments  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([planType])
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================================
// CONSTRUCTION COST ESTIMATOR
// ============================================================================

enum EstimateStatus {
  DRAFT
  ACTIVE
  SENT
  ACCEPTED
  REJECTED
  INVOICED
}

enum EstimateProjectType {
  RESIDENTIAL
  COMMERCIAL
  ROOFING
  RENOVATION
  NEW_CONSTRUCTION
  REPAIR
}

enum MaterialUnit {
  KG
  M
  PCS
  SQFT
  BAG
  TON
  LF
  ROLL
  BOX
  BUNDLE
  GAL
  SHEET
}

enum LabourType {
  MASON
  ELECTRICIAN
  CARPENTER
  ROOFER
  HELPER
  PLUMBER
  PAINTER
  HVAC
  GENERAL
}

enum EquipmentMode {
  RENTAL
  PURCHASE
}

model ConstructionEstimate {
  id                  String              @id @default(uuid())

  // ── Project Details ──
  projectName         String
  projectType         EstimateProjectType @default(RESIDENTIAL)
  status              EstimateStatus      @default(DRAFT)
  currency            Currency            @default(CAD)
  paymentTerms        String?             // e.g. "Net 30", "50% upfront"
  startDate           DateTime?
  endDate             DateTime?

  // ── Address & Geo ──
  address             String
  formattedAddress    String?
  placeId             String?             // Google place_id
  latitude            Float?
  longitude           Float?
  city                String?
  postalCode          String?
  country             String?             @default("CA")
  satelliteImageUrl   String?

  // ── Summary Totals (auto-calculated) ──
  totalMaterialCost   Float               @default(0)
  totalLabourCost     Float               @default(0)
  totalEquipmentCost  Float               @default(0)
  totalTransportCost  Float               @default(0)
  subtotal            Float               @default(0)

  // ── Additional Costs ──
  taxPercent          Float               @default(13)    // GST/HST %
  taxAmount           Float               @default(0)
  overheadPercent     Float               @default(10)
  overheadCost        Float               @default(0)
  profitPercent       Float               @default(15)
  profitMargin        Float               @default(0)
  miscellaneousCost   Float               @default(0)
  safetyEquipmentCost Float               @default(0)
  wastagePercent      Float               @default(5)
  contingencyBudget   Float               @default(0)

  grandTotal          Float               @default(0)

  // ── Notes ──
  clientNotes         String?             @db.Text
  internalNotes       String?             @db.Text
  termsAndConditions  String?             @db.Text

  // ── Relations ──
  tenantId            String
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId            String?
  leadId              String?
  createdBy           String              // employeeId

  // ── Child records ──
  measurements        EstimateMeasurement?
  materials           EstimateMaterial[]
  labour              EstimateLabour[]
  equipment           EstimateEquipment[]
  transport           EstimateTransport[]

  // ── Timestamps ──
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
}

model EstimateMeasurement {
  id                  String              @id @default(uuid())

  // ── EagleView Data ──
  roofArea            Float?              // sq ft
  ridgeLength         Float?              // ft
  valleyLength        Float?              // ft
  hipLength           Float?              // ft
  eaveLength          Float?              // ft
  rakeLength          Float?              // ft
  pitch               String?             // e.g. "6/12"
  facets              Int?
  roofPlanes          Int?
  totalPerimeter      Float?
  slopeChange         Float?
  stepFlashing        Float?
  headwallFlashing    Float?

  // ── Source ──
  source              String?             @default("manual") // eagleview, manual
  eagleViewOrderId    String?
  eagleViewReportId   String?

  // ── Relation ──
  estimateId          String              @unique
  estimate            ConstructionEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([estimateId])
}

model EstimateMaterial {
  id                  String              @id @default(uuid())
  sortOrder           Int                 @default(0)

  materialName        String
  materialCategory    String?             // freeform category
  quantity            Float               @default(0)
  unit                MaterialUnit        @default(PCS)
  ratePerUnit         Float               @default(0)
  totalCost           Float               @default(0)      // quantity × rate
  supplierName        String?
  notes               String?

  // ── Relation ──
  estimateId          String
  estimate            ConstructionEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([estimateId])
}

model EstimateLabour {
  id                  String              @id @default(uuid())
  sortOrder           Int                 @default(0)

  labourType          LabourType          @default(GENERAL)
  description         String?
  numberOfWorkers     Int                 @default(1)
  workingDays         Int                 @default(1)
  hoursPerDay         Float               @default(8)
  ratePerDay          Float               @default(0)
  overtimeHours       Float               @default(0)
  overtimeRate        Float               @default(0)

  baseCost            Float               @default(0)      // workers × days × rate
  overtimeCost        Float               @default(0)      // workers × otHours × otRate
  totalCost           Float               @default(0)      // base + overtime

  // ── Relation ──
  estimateId          String
  estimate            ConstructionEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([estimateId])
}

model EstimateEquipment {
  id                  String              @id @default(uuid())
  sortOrder           Int                 @default(0)

  equipmentName       String
  mode                EquipmentMode       @default(RENTAL)
  numberOfUnits       Int                 @default(1)
  durationDays        Int                 @default(1)
  costPerDay          Float               @default(0)
  totalCost           Float               @default(0)      // units × days × costPerDay

  // ── Relation ──
  estimateId          String
  estimate            ConstructionEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([estimateId])
}

model EstimateTransport {
  id                  String              @id @default(uuid())
  sortOrder           Int                 @default(0)

  transportType       String
  distance            Float?              // km or miles
  numberOfTrips       Int                 @default(1)
  costPerTrip         Float               @default(0)
  totalCost           Float               @default(0)      // trips × costPerTrip

  // ── Relation ──
  estimateId          String
  estimate            ConstructionEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([estimateId])
}

// ============================================================================
// SUPPORT TICKETS MODULE
// ============================================================================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id              String         @id @default(uuid())
  ticketNumber    String
  subject         String
  description     String         @db.Text
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(MEDIUM)
  category        String         @default("Technical")
  requesterUserId String?
  requesterName   String
  requesterEmail  String
  assignee        String?
  messagesCount   Int            @default(0)
  tags            String[]       @default([])
  attachments     Json           @default("[]")

  // ── Tenant scope ──
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ── Messages ──
  messages        TicketMessage[]

  // ── Timestamps ──
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  resolvedAt      DateTime?
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([status])
  @@index([ticketNumber])
  @@index([requesterUserId])
}

model TicketMessage {
  id          String        @id @default(uuid())
  sender      String
  message     String        @db.Text
  isStaff     Boolean       @default(false)
  isInternal  Boolean       @default(false)

  // ── Ticket relation ──
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())

  @@index([ticketId])
}
