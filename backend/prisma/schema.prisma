  shingleProduct  String?
  shingleColor    String?
  
  jobSiteAddress  String?
  jobSiteAddress2 String?
  jobSiteCity     String?
  jobSiteState    String?
  jobSiteZip      String?
  jobSiteCountry  String?         @default("US")
  latitude        Decimal?        @db.Decimal(10, 8)
  longitude       Decimal?        @db.Decimal(11, 8)
  
  // Insurance
  isInsuranceJob  Boolean         @default(false)
  insuranceCompany String?
  claimNumber     String?
  policyNumber    String?
  insuranceApproved Boolean?
  adjusterId      String?
  adjusterName    String?
  adjusterPhone   String?
  adjusterEmail   String?
  dateOfLoss      DateTime?
  
  // Permit
  permitRequired  Boolean         @default(true)
  permitNumber    String?
  permitStatus    PermitStatus?
  permitPulledDate DateTime?
  permitApprovedDate DateTime?
  
