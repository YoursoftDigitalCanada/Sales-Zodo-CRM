// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadTemperature {
  COLD
  WARM
  HOT
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  CHURNED
  PROSPECT
}

enum LeadLifecycleStage {
  SUBSCRIBER     // Signed up / showed initial interest
  LEAD           // Identified as potential customer
  MQL            // Marketing Qualified Lead
  SQL            // Sales Qualified Lead
  OPPORTUNITY    // Active deal in progress
}

enum ClientLifecycleStage {
  NEW_CUSTOMER   // Just converted from lead
  ONBOARDING     // Going through setup / first project
  ACTIVE         // Engaged, recurring work
  AT_RISK        // No activity / signs of churn
  CHURNED        // Lost / inactive customer
  RE_ENGAGED     // Came back after churn
  VIP            // High-value, long-term customer
}

enum ClientType {
  INDIVIDUAL
  BUSINESS
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

enum ContactType {
  CLIENT
  LEAD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum ExpenseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  REIMBURSED
}

enum ExpenseCategory {
  TRAVEL
  MEALS
  OFFICE_SUPPLIES
  SOFTWARE
  HARDWARE
  MARKETING
  UTILITIES
  RENT
  SALARIES
  INSURANCE
  PROFESSIONAL_SERVICES
  TRAINING
  ENTERTAINMENT
  MISCELLANEOUS
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  E_TRANSFER
  CHECK
  PAYPAL
  STRIPE
  OTHER
}

enum Currency {
  USD
  EUR
  GBP
  CAD
  AUD
  INR
  JPY
  CNY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  RETURNED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

enum CalendarEventType {
  MEETING
  CALL
  TASK
  REMINDER
  OUT_OF_OFFICE
  OTHER
}

enum CalendarEventRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum CalendarEventStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum EmailStatus {
  DRAFT
  SENT
  RECEIVED
  FAILED
}

enum EmailFolder {
  INBOX
  SENT
  DRAFTS
  TRASH
  SPAM
  ARCHIVE
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  SYSTEM
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  PERMISSION_CHANGE
  PASSWORD_CHANGE
  STATUS_CHANGE
}

// ============================================================================
// TENANT & USER MANAGEMENT
// ============================================================================

model Tenant {
  id                    String        @id @default(uuid())
  name                  String
  slug                  String        @unique
  domain                String?       @unique
  status                TenantStatus  @default(TRIAL)
  logo                  String?
  
  // Settings stored as JSON for flexibility
  settings              Json          @default("{}")
  
  // Storage quotas
  fileStorageQuota      BigInt        @default(5368709120) // 5GB
  fileStorageUsed       BigInt        @default(0)
  emailStorageQuota     BigInt        @default(1073741824) // 1GB
  emailStorageUsed      BigInt        @default(0)
  
  // Subscription info (basic - extend as needed)
  subscriptionTier      String        @default("free")
  subscriptionExpiresAt DateTime?
  
  // Onboarding lifecycle flag — set TRUE only after seedTenant() completes
  onboardingCompleted   Boolean       @default(false)
  
  // Timestamps
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  // Relations
  users                 User[]
  employees             Employee[]
  roles                 Role[]
  leads                 Lead[]
  clients               Client[]
  contacts              Contact[]
  clientGroups          ClientGroup[]
  applications          Application[]
  tasks                 Task[]
  projects              Project[]
  calendarEvents        CalendarEvent[]
  files                 File[]
  folders               Folder[]
  invoices              Invoice[]
  expenses              Expense[]
  expenseBudgets        ExpenseBudget[]
  bookings              Booking[]
  services              Service[]
  products              Product[]
  productCategories     ProductCategory[]
  orders                Order[]
  emails                Email[]
  emailLabels           EmailLabel[]
  chatRooms             ChatRoom[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  leadSources           LeadSource[]
  tenantSettings        TenantSettings?
  tags                  Tag[]
  roofEstimates         RoofEstimate[]
  roofEstimateSettings  RoofEstimateSettings?
  payments              InvoicePayment[]
  quotes                Quote[]
  contracts             Contract[]

  @@index([status])
  @@index([slug])
}

model User {
  id                    String        @id @default(uuid())
  email                 String        @unique
  passwordHash          String
  firstName             String
  lastName              String
  avatar                String?
  phone                 String?
  status                UserStatus    @default(PENDING_VERIFICATION)
  emailVerified         Boolean       @default(false)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  passwordChangedAt     DateTime?
  
  // Preferences stored as JSON
  preferences           Json          @default("{}")
  
  // Timestamps
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  // Tenant relation (optional - user can exist without tenant initially)
  tenantId              String?
  tenant                Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  
  // Relations
  refreshTokens         RefreshToken[]
  employees             Employee[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  userPreferences       UserPreferences?

  @@index([email])
  @@index([tenantId])
  @@index([status])
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  replacedBy  String?   // For token rotation
  userAgent   String?
  ipAddress   String?

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Employee {
  id                    String        @id @default(uuid())
  employeeNumber        String?       // Optional employee ID/number
  department            String?
  position              String?
  hireDate              DateTime?
  isActive              Boolean       @default(true)
  
  // Tenant relation (REQUIRED for employees)
  tenantId              String
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // User relation
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Role relation
  roleId                String
  role                  Role          @relation(fields: [roleId], references: [id])
  
  // Timestamps
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  // Relations
  assignedLeads         Lead[]        @relation("AssignedToEmployee")
  createdLeads          Lead[]        @relation("CreatedByEmployee")
  assignedClients       Client[]      @relation("AssignedToEmployee")
  assignedTasks         Task[]        @relation("AssignedToEmployee")
  createdTasks          Task[]        @relation("CreatedByEmployee")
  projectMembers        ProjectMember[]
  createdInvoices       Invoice[]     @relation("CreatedByEmployee")
  createdExpenses       Expense[]     @relation("CreatedByEmployee")
  approvedExpenses      Expense[]     @relation("ApprovedByEmployee")
  assignedBookings      Booking[]
  sentEmails            Email[]       @relation("SentByEmployee")
  chatParticipations    ChatParticipant[]
  calendarEvents        CalendarEvent[] @relation("CreatedByEmployee")
  eventAttendees        CalendarEventAttendee[]
  createdQuotes         Quote[]         @relation("CreatedByEmployee")
  createdContracts      Contract[]      @relation("ContractCreatedBy")

  @@unique([tenantId, userId])
  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([isActive])
}

// ============================================================================
// RBAC - ROLES & PERMISSIONS
// ============================================================================

model Role {
  id              String        @id @default(uuid())
  name            String
  description     String?
  isSystemRole    Boolean       @default(false) // Owner, Admin, etc. cannot be deleted
  isDefault       Boolean       @default(false) // Default role for new employees
  
  // Tenant relation
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  employees       Employee[]
  permissions     RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isSystemRole])
}

model Permission {
  id              String        @id @default(uuid())
  code            String        @unique // e.g., "leads.view", "leads.create"
  name            String
  description     String?
  module          String        // e.g., "leads", "clients", "invoices"
  action          String        // e.g., "view", "create", "update", "delete"
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  roles           RolePermission[]

  @@unique([module, action])
  @@index([module])
  @@index([code])
}

model RolePermission {
  id              String      @id @default(uuid())
  
  roleId          String
  role            Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  permissionId    String
  permission      Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  // Optional constraints (for future use)
  constraints     Json?       // e.g., {"ownOnly": true}
  
  createdAt       DateTime    @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ============================================================================
// LEADS MODULE
// ============================================================================

model LeadSource {
  id              String      @id @default(uuid())
  name            String
  description     String?
  isActive        Boolean     @default(true)
  
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  leads           Lead[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isActive])
}

model Lead {
  id                String          @id @default(uuid())
  
  // Basic Info
  firstName         String
  lastName          String
  email             String?
  phone             String?
  location          String?
  
  // Company Info
  companyName       String?
  jobTitle          String?
  website           String?
  
  // Lead Classification
  status            LeadStatus          @default(NEW)
  temperature       LeadTemperature     @default(WARM)
  lifecycleStage    LeadLifecycleStage  @default(LEAD)
  potentialValue    Decimal?            @db.Decimal(15, 2)
  
  // Source
  leadSourceId      String?
  leadSource        LeadSource?     @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  
  // Assignment
  assignedToId      String?
  assignedTo        Employee?       @relation("AssignedToEmployee", fields: [assignedToId], references: [id], onDelete: SetNull)
  
  // Notes
  notes             String?         @db.Text
  
  // Conversion tracking
  convertedAt       DateTime?
  convertedToClientId String?
  
  // Tenant relation
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Created by
  createdById       String?
  createdBy         Employee?       @relation("CreatedByEmployee", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  // Relations
  tags              LeadTag[]
  calendarEvents    CalendarEvent[]
  activities        LeadActivity[]

  @@index([tenantId])
  @@index([status])
  @@index([temperature])
  @@index([assignedToId])
  @@index([leadSourceId])
  @@index([createdAt])
}

model LeadTag {
  id        String   @id @default(uuid())
  
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
  @@index([leadId])
  @@index([tagId])
}

model LeadActivity {
  id          String    @id @default(uuid())
  type        String    // e.g., "note", "email", "call", "meeting", "status_change"
  title       String
  description String?   @db.Text
  metadata    Json?     // Additional data based on type
  
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================================
// CLIENTS MODULE
// ============================================================================

model Client {
  id                      String        @id @default(uuid())
  
  // 1️⃣ Basic Information
  clientLogo              String?
  clientName              String
  companyName             String?
  clientType              ClientType    @default(BUSINESS)
  primaryEmail            String
  primaryPhone            String
  status                  ClientStatus          @default(ACTIVE)
  lifecycleStage          ClientLifecycleStage   @default(NEW_CUSTOMER)
  assignedOwnerId         String?
  assignedOwner           Employee?     @relation("AssignedToEmployee", fields: [assignedOwnerId], references: [id], onDelete: SetNull)
  
  // 2️⃣ Business & Tax Details
  gstHstNumber            String?
  pstQstNumber            String?
  businessStructure       String?
  corpRegistrationNumber  String?
  
  // 3️⃣ Billing Address
  streetAddress           String?
  suite                   String?
  city                    String?
  province                String?
  postalCode              String?
  country                 String?
  
  // 4️⃣ Internal Notes
  internalNotes           String?       @db.Text
  
  // 5️⃣ Primary Contact
  contactName             String?
  position                String?
  directPhone             String?
  
  // 6️⃣ Financial Settings
  creditLimit             Decimal?      @db.Decimal(15, 2)
  paymentTerms            String?
  currency                String        @default("CAD")
  
  // 7️⃣ Categorization
  leadSource              String?
  clientCategory          String?
  tags                    Json          @default("[]")
  
  // Tracking
  totalRevenue            Decimal       @default(0) @db.Decimal(15, 2)
  
  // Tenant relation
  tenantId                String
  tenant                  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  
  // Relations
  contacts                Contact[]
  groups                  ClientGroupMember[]
  projects                Project[]
  invoices                Invoice[]
  quotes                  Quote[]
  orders                  Order[]
  bookings                Booking[]
  tasks                   Task[]
  files                   File[]
  emails                  Email[]
  payments                InvoicePayment[]
  roofEstimates           RoofEstimate[]
  calendarEvents          CalendarEvent[]
  contracts               Contract[]

  @@index([tenantId])
  @@index([status])
  @@index([clientType])
  @@index([assignedOwnerId])
  @@index([primaryEmail])
}

// ============================================================================
// CONTACTS MODULE
// ============================================================================

model Contact {
  id                String        @id @default(uuid())
  
  // Contact Info
  contactName       String
  type              ContactType   @default(CLIENT)
  jobTitle          String?
  department        String?
  email             String
  officePhone       String?
  mobilePhone       String?
  linkedInUrl       String?
  
  // Flags
  isPrimaryContact  Boolean       @default(false)
  
  // Client relation (optional - can be standalone contact)
  companyId         String?
  company           Client?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([tenantId])
  @@index([companyId])
  @@index([isPrimaryContact])
  @@index([email])
  @@index([type])

  // Relations
  emails                Email[]
}

// ============================================================================
// CLIENT GROUPS MODULE
// ============================================================================

model ClientGroup {
  id                  String      @id @default(uuid())
  name                String
  description         String?
  color               String?     // For UI display
  
  // Auto-update rules (stored as JSON)
  autoUpdateEnabled   Boolean     @default(false)
  autoUpdateRules     Json?       // e.g., {"industry": "Technology", "status": "ACTIVE"}
  
  // Tenant relation
  tenantId            String
  tenant              Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  members             ClientGroupMember[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ClientGroupMember {
  id            String        @id @default(uuid())
  
  groupId       String
  group         ClientGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  addedAt       DateTime      @default(now())
  addedManually Boolean       @default(true) // vs auto-added by rules

  @@unique([groupId, clientId])
  @@index([groupId])
  @@index([clientId])
}

// ============================================================================
// APPLICATIONS MODULE
// ============================================================================

model Application {
  id              String            @id @default(uuid())
  
  // Application Info
  referenceNumber String
  title           String
  description     String?           @db.Text
  
  // Status & Lifecycle
  status          ApplicationStatus @default(DRAFT)
  submittedAt     DateTime?
  reviewedAt      DateTime?
  completedAt     DateTime?
  
  // Form Data (flexible JSON for different application types)
  formData        Json              @default("{}")
  
  // Attachments tracked via File model with applicationId
  
  // Notes
  internalNotes   String?           @db.Text
  
  // Tenant relation
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relations
  files           File[]

  @@unique([tenantId, referenceNumber])
  @@index([tenantId])
  @@index([status])
  @@index([referenceNumber])
}

// ============================================================================
// TASKS MODULE
// ============================================================================

model Task {
  id              String        @id @default(uuid())
  
  // Task Info
  title           String
  description     String?       @db.Text
  
  // Status & Priority
  status          TaskStatus    @default(TODO)
  priority        TaskPriority  @default(MEDIUM)
  
  // Dates
  dueDate         DateTime?
  startDate       DateTime?
  completedAt     DateTime?
  
  // Estimation (in minutes)
  estimatedTime   Int?
  actualTime      Int?
  
  // Assignment
  assignedToId    String?
  assignedTo      Employee?     @relation("AssignedToEmployee", fields: [assignedToId], references: [id], onDelete: SetNull)
  
  // Created by
  createdById     String?
  createdBy       Employee?     @relation("CreatedByEmployee", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Project relation (optional)
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  // Client relation (optional)
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  tags            TaskTag[]
  subtasks        Task[]        @relation("TaskSubtasks")
  parentTask      Task?         @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  parentTaskId    String?

  @@index([tenantId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([projectId])
  @@index([dueDate])
}

model TaskTag {
  id        String   @id @default(uuid())
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
}

// ============================================================================
// PROJECTS MODULE
// ============================================================================

model Project {
  id              String          @id @default(uuid())
  
  // Project Info
  name            String
  description     String?         @db.Text
  code            String?         // Project code/identifier
  
  // Status
  status          ProjectStatus   @default(PLANNING)
  
  // Dates
  startDate       DateTime?
  endDate         DateTime?
  actualEndDate   DateTime?
  
  // Budget
  budget          Decimal?        @db.Decimal(15, 2)
  currency        Currency        @default(USD)
  
  // Progress (0-100)
  progress        Int             @default(0)
  
  // Client relation (optional)
  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  archivedAt      DateTime?       // FUTURE: Archived functionality
  
  // Relations
  tasks           Task[]
  members         ProjectMember[]
  files           File[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@index([clientId])
}

model ProjectMember {
  id          String    @id @default(uuid())
  role        String?   // e.g., "Project Manager", "Developer"
  
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  joinedAt    DateTime  @default(now())

  @@unique([projectId, employeeId])
  @@index([projectId])
  @@index([employeeId])
}

