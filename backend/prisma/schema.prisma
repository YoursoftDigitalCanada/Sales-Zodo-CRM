  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  archivedAt      DateTime?       // FUTURE: Archived functionality
  
  // Relations
  tasks           Task[]
  projectTasks    ProjectTask[]
  projectMaterials ProjectMaterial[]
  projectLaborEntries ProjectLabor[]
  projectExpenses ProjectExpense[]
  projectDocuments ProjectDocument[]
  projectPhotos   ProjectPhoto[]
  projectNotes    ProjectNote[]
  projectCommunications ProjectCommunication[]
  crewAssignments ProjectCrewAssignment[]
  projectInspections ProjectInspection[]
  changeOrders    ChangeOrder[]
  weatherDelays   WeatherDelay[]
  purchaseOrders  PurchaseOrder[]
  projectStageHistory ProjectStageHistory[]
  members         ProjectMember[]
  files           File[]
  invoices        Invoice[]
  payments        InvoicePayment[]
  emails          Email[]
  contracts       Contract[]
