  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId])
  @@index([employeeId])
  @@index([projectId])
  @@index([status])
  @@index([startTime])

  locationPings   LocationPing[]
}

