// ============================================================================
// CALENDAR MODULE
// ============================================================================

model CalendarEvent {
  id              String                    @id @default(uuid())
  
  // Event Info
  title           String
  description     String?                   @db.Text
  location        String?
  
  // Type & Color
  eventType       CalendarEventType         @default(MEETING)
  status          CalendarEventStatus       @default(SCHEDULED)
  color           String?
  
  // Timing
  startTime       DateTime
  endTime         DateTime
  isAllDay        Boolean                   @default(false)
  timezone        String                    @default("UTC")
  
  // Recurrence
  recurrence      CalendarEventRecurrence   @default(NONE)
  recurrenceRule  String?                   // iCal RRULE format for complex rules
  recurrenceEndDate DateTime?
  
  // Notifications
  reminderMinutes Int?                      // Minutes before event
  
  // Additional fields
  meetingLink     String?
  priority        String                    @default("MEDIUM") // LOW, MEDIUM, HIGH
  isPrivate       Boolean                   @default(false)
  notes           String?                   @db.Text
  category        String?                   // work, meeting, personal, client, deadline, holiday, travel, training
  
  // Creator
  createdById     String?
  createdBy       Employee?                 @relation("CreatedByEmployee", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId        String
  tenant          Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Client / Lead linking (for automation context)
  clientId        String?
  client          Client?                   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadId          String?
  lead            Lead?                     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  
  // Relations
  attendees       CalendarEventAttendee[]

  @@index([tenantId])
  @@index([startTime])
  @@index([endTime])
  @@index([eventType])
  @@index([status])
  @@index([createdById])
  @@index([clientId])
  @@index([leadId])
}

model CalendarEventAttendee {
  id              String          @id @default(uuid())
  
  eventId         String
  event           CalendarEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  employeeId      String
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  status          String          @default("pending") // pending, accepted, declined, tentative
  respondedAt     DateTime?

  @@unique([eventId, employeeId])
  @@index([eventId])
  @@index([employeeId])
}

// ============================================================================
// FILE MANAGER MODULE
// ============================================================================

model Folder {
  id              String      @id @default(uuid())
  name            String
  
  // Parent folder (for nested structure)
  parentId        String?
  parent          Folder?     @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children        Folder[]    @relation("FolderHierarchy")
  
  // Sharing
  isShared        Boolean     @default(false)
  sharedWith      Json?       // Array of employee IDs or "all"
  
  // Tenant relation
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?   // Soft delete for trash
  
  // Relations
  files           File[]

  @@index([tenantId])
  @@index([parentId])
  @@index([deletedAt])
}

model File {
  id              String      @id @default(uuid())
  
  // File Info
  name            String
  originalName    String
  mimeType        String
  size            BigInt      // in bytes
  path            String      // Storage path
  
  // Metadata
  extension       String?
  checksum        String?     // For integrity verification
  
  // Folder relation (optional)
  folderId        String?
  folder          Folder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  
  // Related entities (optional - file can belong to multiple contexts)
  applicationId   String?
  application     Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  
  projectId       String?
  project         Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  clientId        String?
  client          Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  // Sharing
  isShared        Boolean     @default(false)
  sharedWith      Json?       // Array of employee IDs or "all"
  shareLink       String?     @unique // Public share link
  shareExpiresAt  DateTime?
  
  // Tenant relation
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?   // Soft delete for trash
  
  // Relations
  tags            FileTag[]

  @@index([tenantId])
  @@index([folderId])
  @@index([mimeType])
  @@index([deletedAt])
  @@index([applicationId])
  @@index([projectId])
  @@index([clientId])
}

model FileTag {
  id        String   @id @default(uuid())
  
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([fileId, tagId])
  @@index([fileId])
  @@index([tagId])
}

// ============================================================================
// INVOICES MODULE
// ============================================================================

model Invoice {
  id                String          @id @default(uuid())
  
  // Invoice Number
  invoiceNumber     String
  
  // Status
  status            InvoiceStatus   @default(DRAFT)
  
  // Client
  clientId          String
  client            Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  // Dates
  issueDate         DateTime        @default(now())
  dueDate           DateTime
  paidAt            DateTime?
  
  // Currency
  currency          Currency        @default(USD)
  
  // Amounts
  subtotal          Decimal         @db.Decimal(15, 2)
  taxRate           Decimal?        @db.Decimal(5, 2) // Percentage
  taxAmount         Decimal         @default(0) @db.Decimal(15, 2)
  discountAmount    Decimal         @default(0) @db.Decimal(15, 2)
  total             Decimal         @db.Decimal(15, 2)
  amountPaid        Decimal         @default(0) @db.Decimal(15, 2)
  amountDue         Decimal         @db.Decimal(15, 2)
  
  // Notes
  notes             String?         @db.Text
  terms             String?         @db.Text
  
  // Created by
  createdById       String?
  createdBy         Employee?       @relation("CreatedByEmployee", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  sentAt            DateTime?
  viewedAt          DateTime?
  
  // Relations
  items             InvoiceItem[]
  payments          InvoicePayment[]

  // FUTURE: Recurring invoice fields
  // isRecurring       Boolean         @default(false)
  // recurringInterval String?         // e.g., "monthly", "quarterly"
  // recurringEndDate  DateTime?
  // parentInvoiceId   String?

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([status])
  @@index([clientId])
  @@index([dueDate])
}

model InvoiceItem {
  id              String    @id @default(uuid())
  
  invoiceId       String
  invoice         Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  // Item details
  description     String
  quantity        Decimal   @db.Decimal(10, 2)
  unitPrice       Decimal   @db.Decimal(15, 2)
  amount          Decimal   @db.Decimal(15, 2)
  
  // Optional: tax per item
  taxRate         Decimal?  @db.Decimal(5, 2)
  
  // Ordering
  sortOrder       Int       @default(0)

  @@index([invoiceId])
}

model InvoicePayment {
  id              String        @id @default(uuid())
  
  // Invoice link (optional — allows standalone payments like deposits, retainers)
  invoiceId       String?
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  // Client link (required — every payment belongs to a client)
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  // Payment details
  amount          Decimal       @db.Decimal(15, 2)
  paymentMethod   PaymentMethod
  paymentDate     DateTime      @default(now())
  reference       String?       // Transaction ID, check number, e-transfer ref, etc.
  notes           String?
  
  // Tenant relation
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([invoiceId])
  @@index([clientId])
  @@index([tenantId])
  @@index([paymentDate])
}

// ============================================================================
// EXPENSES MODULE
// ============================================================================

model Expense {
  id                String          @id @default(uuid())
  
  // Expense Info
  title             String
  description       String?         @db.Text
  
  // Category & Amount
  category          ExpenseCategory
  amount            Decimal         @db.Decimal(15, 2)
  currency          Currency        @default(USD)
  
  // Payment Info
  paymentMethod     PaymentMethod
  paymentDate       DateTime
  
  // Vendor/Merchant
  vendor            String?
  receiptNumber     String?
  
  // Status & Approval
  status            ExpenseStatus   @default(DRAFT)
  
  // Reimbursement
  isReimbursable    Boolean         @default(false)
  reimbursedAt      DateTime?
  
  // Created by
  createdById       String
  createdBy         Employee        @relation("CreatedByEmployee", fields: [createdById], references: [id], onDelete: Restrict)
  
  // Approved by
  approvedById      String?
  approvedBy        Employee?       @relation("ApprovedByEmployee", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt        DateTime?
  approvalNotes     String?
  
  // Budget relation (optional)
  budgetId          String?
  budget            ExpenseBudget?  @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([category])
  @@index([createdById])
  @@index([paymentDate])
}

model ExpenseBudget {
  id              String          @id @default(uuid())
  
  name            String
  category        ExpenseCategory?
  amount          Decimal         @db.Decimal(15, 2)
  currency        Currency        @default(USD)
  
  // Period
  startDate       DateTime
  endDate         DateTime
  
  // Tracking
  spent           Decimal         @default(0) @db.Decimal(15, 2)
  
  // Tenant relation
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  expenses        Expense[]

  @@index([tenantId])
  @@index([category])
  @@index([startDate, endDate])
}

// ============================================================================
// BOOKINGS MODULE
// ============================================================================

model Booking {
  id              String          @id @default(uuid())
  
  // Booking Info
  title           String
  description     String?         @db.Text
  
  // Status
  status          BookingStatus   @default(PENDING)
  
  // Timing
  startTime       DateTime
  endTime         DateTime
  timezone        String          @default("UTC")
  
  // Client
  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  // External guest (if not a client)
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  
  // Assignment
  assignedToId    String?
  assignedTo      Employee?       @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  
  // Location
  location        String?
  isOnline        Boolean         @default(false)
  meetingLink     String?
  
  // Notes
  notes           String?         @db.Text
  
  // Tenant relation
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  confirmedAt     DateTime?
  cancelledAt     DateTime?

  // Service relation (optional)
  serviceId       String?
  service         Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([startTime])
  @@index([clientId])
  @@index([assignedToId])
  @@index([serviceId])
}

// ============================================================================
// SERVICES MODULE
// ============================================================================

model Service {
  id              String    @id @default(uuid())

  // Service Info
  name            String
  description     String?   @db.Text
  category        String?

  // Pricing & Duration
  basePrice       Decimal?  @db.Decimal(15, 2)
  durationMinutes Int?

  // Status
  isActive        Boolean   @default(true)

  // Tenant relation
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  bookings        Booking[]

  @@index([tenantId])
  @@index([category])
  @@index([isActive])
}

// ============================================================================
// ECOMMERCE MODULE
// ============================================================================

model ProductCategory {
  id              String      @id @default(uuid())
  name            String
  description     String?
  slug            String
  parentId        String?
  parent          ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        ProductCategory[] @relation("CategoryHierarchy")
  
  // Display
  image           String?
  sortOrder       Int         @default(0)
  isActive        Boolean     @default(true)
  
  // Tenant relation
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  products        Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@index([isActive])
}

model Product {
  id              String          @id @default(uuid())
  
  // Product Info
  name            String
  description     String?         @db.Text
  sku             String
  slug            String
  
  // Pricing
  price           Decimal         @db.Decimal(15, 2)
  compareAtPrice  Decimal?        @db.Decimal(15, 2) // Original price for showing discount
  costPrice       Decimal?        @db.Decimal(15, 2) // Cost for profit calculation
  currency        Currency        @default(USD)
  
  // Inventory
  trackInventory  Boolean         @default(true)
  quantity        Int             @default(0)
  lowStockThreshold Int?
  
  // Status
  status          ProductStatus   @default(ACTIVE)
  
  // Category
  categoryId      String?
  category        ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  // Media
  images          Json            @default("[]") // Array of image URLs
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Physical properties
  weight          Decimal?        @db.Decimal(10, 2)
  weightUnit      String?         @default("kg")
  
  // Tenant relation
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  orderItems      OrderItem[]

  @@unique([tenantId, sku])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([status])
  @@index([categoryId])
}

model Order {
  id              String        @id @default(uuid())
  
  // Order Number
  orderNumber     String
  
  // Status
  status          OrderStatus   @default(PENDING)
  
  // Client
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  // Customer Info (for guest orders)
  customerEmail   String
  customerName    String
  customerPhone   String?
  
  // Addresses
  billingAddress  Json
  shippingAddress Json
  
  // Currency
  currency        Currency      @default(USD)
  
  // Amounts
  subtotal        Decimal       @db.Decimal(15, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(15, 2)
  shippingAmount  Decimal       @default(0) @db.Decimal(15, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(15, 2)
  total           Decimal       @db.Decimal(15, 2)
  
  // Payment
  paymentMethod   PaymentMethod?
  paymentStatus   String        @default("pending") // pending, paid, failed, refunded
  paidAt          DateTime?
  
  // Shipping
  shippingMethod  String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  
  // Notes
  notes           String?       @db.Text
  internalNotes   String?       @db.Text
  
  // Tenant relation
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  items           OrderItem[]

  // FUTURE: Coupon relation
  // couponId        String?
  // couponCode      String?

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([status])
  @@index([clientId])
  @@index([customerEmail])
}

model OrderItem {
  id              String    @id @default(uuid())
  
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  // Snapshot of product at time of order
  productName     String
  productSku      String
  
  quantity        Int
  unitPrice       Decimal   @db.Decimal(15, 2)
  total           Decimal   @db.Decimal(15, 2)

  @@index([orderId])
  @@index([productId])
}

