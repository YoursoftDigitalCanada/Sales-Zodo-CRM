model TimeEntry {
  id              String          @id @default(uuid())
  description     String?

  // Clock times
  startTime       DateTime
  endTime         DateTime?
  duration        Int?            // in minutes (auto-calc on clock-out)

  // Billing
  billable        Boolean         @default(true)
  hourlyRate      Decimal?        @db.Decimal(10, 2)

  // Phase / category
  phase           String?         // Inspection, Tear-off, Install, Cleanup, Travel
  notes           String?         @db.Text

  // GPS
  clockInLat      Float?
  clockInLng      Float?
  clockOutLat     Float?
  clockOutLng     Float?

  // Status
  status          TimeEntryStatus @default(CLOCKED_IN)

  // Relations
  taskId          String?
  task            Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)

  projectId       String?
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)

  employeeId      String
