  clientReviewReceived Boolean    @default(false)
  
  // Job site and roof metadata
  roofType        String?
  roofSquares     Decimal?        @db.Decimal(10, 2)
  roofPitch       String?
  roofLayers      Int?            @default(1)
  stories         Int?            @default(1)
