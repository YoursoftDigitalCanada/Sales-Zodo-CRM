// ============================================================================
// COMMUNICATION - EMAIL (LETTER BOX)
// ============================================================================

model EmailLabel {
  id              String      @id @default(uuid())
  name            String
  color           String?
  
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime    @default(now())
  
  emails          EmailLabelAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Email {
  id              String        @id @default(uuid())
  
  // Email metadata
  messageId       String?       @unique // For external email systems
  threadId        String?       // For conversation threading
  
  // Sender/Recipients
  fromAddress     String
  fromName        String?
  toAddresses     Json          // Array of {email, name}
  ccAddresses     Json?         // Array of {email, name}
  bccAddresses    Json?         // Array of {email, name}
  replyTo         String?
  
  // Content
  subject         String
  bodyText        String?       @db.Text
  bodyHtml        String?       @db.Text
  
  // Status & Folder
  status          EmailStatus   @default(RECEIVED)
  folder          EmailFolder   @default(INBOX)
  
  // Flags
  isRead          Boolean       @default(false)
  isStarred       Boolean       @default(false)
  hasAttachments  Boolean       @default(false)
  
  // Size (for quota)
  size            BigInt        @default(0)
  
  // Sent by (if outgoing)
  sentById        String?
  sentBy          Employee?     @relation("SentByEmployee", fields: [sentById], references: [id], onDelete: SetNull)
  
  // Entity links (optional — link emails to CRM entities)
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  contactId       String?
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  
  // Timestamps
  sentAt          DateTime?
  receivedAt      DateTime?
  
  // Tenant relation
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?     // Soft delete for trash
  
  // Relations
  labels          EmailLabelAssignment[]
  attachments     EmailAttachment[]

  @@index([tenantId])
  @@index([folder])
  @@index([status])
  @@index([sentById])
  @@index([threadId])
  @@index([isRead])
  @@index([deletedAt])
  @@index([clientId])
  @@index([contactId])
}

model EmailLabelAssignment {
  id        String      @id @default(uuid())
  
  emailId   String
  email     Email       @relation(fields: [emailId], references: [id], onDelete: Cascade)
  
  labelId   String
  label     EmailLabel  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([emailId, labelId])
  @@index([emailId])
  @@index([labelId])
}

model EmailAttachment {
  id              String    @id @default(uuid())
  
  emailId         String
  email           Email     @relation(fields: [emailId], references: [id], onDelete: Cascade)
  
  filename        String
  mimeType        String
  size            BigInt
  path            String

  @@index([emailId])
}

// ============================================================================
// COMMUNICATION - CHAT
// ============================================================================

model ChatRoom {
  id              String      @id @default(uuid())
  
  // Room Info
  name            String?     // Null for 1-to-1 chats
  isGroup         Boolean     @default(false)
  
  // Last message for quick access
  lastMessageAt   DateTime?
  lastMessagePreview String?
  
  // Tenant relation
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  participants    ChatParticipant[]
  messages        ChatMessage[]

  @@index([tenantId])
  @@index([lastMessageAt])
}

model ChatParticipant {
  id              String      @id @default(uuid())
  
  roomId          String
  room            ChatRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  // Role in group chat
  role            String      @default("member") // admin, member
  
  // Read tracking
  lastReadAt      DateTime?
  unreadCount     Int         @default(0)
  
  // Timestamps
  joinedAt        DateTime    @default(now())
  leftAt          DateTime?

  @@unique([roomId, employeeId])
  @@index([roomId])
  @@index([employeeId])
}

model ChatMessage {
  id              String      @id @default(uuid())
  
  roomId          String
  room            ChatRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  // Sender (null for system messages)
  senderId        String?
  
  // Content
  content         String      @db.Text
  messageType     String      @default("text") // text, image, file, system
  
  // Attachments (stored as JSON for flexibility)
  attachments     Json?
  
  // Status
  isEdited        Boolean     @default(false)
  editedAt        DateTime?
  
  // Timestamps
  createdAt       DateTime    @default(now())
  deletedAt       DateTime?   // Soft delete

  @@index([roomId])
  @@index([senderId])
  @@index([createdAt])
}

// ============================================================================
// NOTIFICATIONS MODULE (CONTINUED)
// ============================================================================

model Notification {
  id              String            @id @default(uuid())
  
  // Content
  title           String
  message         String            @db.Text
  type            NotificationType  @default(INFO)
  
  // Action (optional link)
  actionUrl       String?
  actionLabel     String?
  
  // Metadata (flexible JSON for additional data)
  metadata        Json?
  
  // Target user
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Read status
  isRead          Boolean           @default(false)
  readAt          DateTime?
  
  // Tenant relation
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime          @default(now())
  expiresAt       DateTime?         // Optional expiration

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
}

// ============================================================================
// AUDIT LOGS MODULE
// ============================================================================

model AuditLog {
  id              String        @id @default(uuid())
  
  // Action details
  action          AuditAction
  module          String        // e.g., "auth", "leads", "invoices"
  description     String
  
  // Entity reference
  entityType      String?       // e.g., "Lead", "Invoice"
  entityId        String?
  
  // Changes (for update actions)
  oldValues       Json?
  newValues       Json?
  
  // Request info
  ipAddress       String?
  userAgent       String?
  requestMethod   String?
  requestPath     String?
  
  // User who performed action
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamp
  createdAt       DateTime      @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================================================
// TAGS (SHARED ACROSS MODULES)
// ============================================================================

model Tag {
  id              String      @id @default(uuid())
  name            String
  color           String?     // Hex color for UI
  
  // Tenant relation
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  leads           LeadTag[]
  tasks           TaskTag[]
  files           FileTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ============================================================================
// SETTINGS (TENANT & USER PREFERENCES)
// ============================================================================

model TenantSettings {
  id              String      @id @default(uuid())
  
  tenantId        String      @unique
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // General Settings
  timezone        String      @default("UTC")
  dateFormat      String      @default("YYYY-MM-DD")
  timeFormat      String      @default("HH:mm")
  currency        Currency    @default(USD)
  language        String      @default("en")
  
  // Business Settings
  fiscalYearStart Int         @default(1) // Month (1-12)
  
  // Invoice Settings
  invoicePrefix   String      @default("INV-")
  invoiceNextNumber Int       @default(1)
  invoiceTerms    String?     @db.Text
  invoiceNotes    String?     @db.Text
  
  // Email Settings
  emailSignature  String?     @db.Text
  
  // Notification Preferences (JSON)
  notificationSettings Json   @default("{}")
  
  // Integration Flags (for future integrations)
  integrations    Json        @default("{}")
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model UserPreferences {
  id              String      @id @default(uuid())
  
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // UI Preferences
  theme           String      @default("light") // light, dark, system
  sidebarCollapsed Boolean    @default(false)
  language        String      @default("en")
  
  // Notification Preferences
  emailNotifications Boolean  @default(true)
  pushNotifications Boolean   @default(true)
  notificationSound Boolean   @default(true)
  
  // Dashboard Preferences (JSON for widget layout)
  dashboardLayout Json        @default("{}")
  
  // Table Preferences (columns, sorting, etc.)
  tablePreferences Json       @default("{}")
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ============================================================================
// ROOF ESTIMATOR MODULE
// ============================================================================

model RoofEstimate {
  id                String    @id @default(uuid())

  // Address & Geo
  address           String
  latitude          Float
  longitude         Float
  satelliteImageUrl String?

  // AI Results
  roofAreaSqft      Float
  confidence        Float     @default(0)
  processingTimeSec Float     @default(0)
  aiModel           String    @default("yolov8n-seg-cpu")

  // Pricing
  pricePerSqft      Float     @default(0)
  manualAdjustment  Float     @default(0) // percentage adjustment
  totalEstimate     Float     @default(0)

  // Flags
  snowMode          Boolean   @default(false)
  notes             String?   @db.Text
  pdfUrl            String?

  // Relations
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId          String?
  client            Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  createdBy         String

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Back-relations
  quotes            Quote[]

  @@index([tenantId])
  @@index([clientId])
  @@index([createdAt])
}

model RoofEstimateSettings {
  id                String    @id @default(uuid())

  tenantId          String    @unique
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  defaultPricePerSqft Float   @default(5.50)
  currency          String    @default("CAD")
  snowModeDefault   Boolean   @default(true)
  companyName       String?   // For PDF branding
  companyLogo       String?
  companyPhone      String?
  companyEmail      String?
  companyAddress    String?
  pdfFooterText     String?   @db.Text

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ============================================================================
// QUOTES / PROPOSALS MODULE
// ============================================================================

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quote {
  id                String          @id @default(uuid())
  
  // Quote Number (auto-generated like invoices)
  quoteNumber       String
  
  // Status
  status            QuoteStatus     @default(DRAFT)
  
  // Client (optional — may be lead-only)
  clientId          String?
  client            Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  // Lead (optional — for pre-client quotes)
  leadId            String?
  
  // Dates
  issueDate         DateTime        @default(now())
  validUntil        DateTime
  
  // Currency
  currency          String          @default("CAD")
  
  // Amounts
  subtotal          Decimal         @db.Decimal(15, 2)
  taxRate           Decimal?        @db.Decimal(5, 2)
  taxAmount         Decimal         @default(0) @db.Decimal(15, 2)
  discountAmount    Decimal         @default(0) @db.Decimal(15, 2)
  total             Decimal         @db.Decimal(15, 2)
  
  // Notes & Terms
  notes             String?         @db.Text
  terms             String?         @db.Text
  
  // Source context (which meeting triggered this)
  sourceEventId     String?         // Calendar event that triggered quote creation
  
  // Linked roof estimate (for PDF attachment on send)
  roofEstimateId    String?
  roofEstimate      RoofEstimate?   @relation(fields: [roofEstimateId], references: [id], onDelete: SetNull)
  
  // Created by
  createdById       String?
  createdBy         Employee?       @relation("CreatedByEmployee", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Public access token for email link
  publicToken       String?         @unique
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  sentAt            DateTime?
  acceptedAt        DateTime?
  
  // Relations
  items             QuoteItem[]

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
  @@index([status])
  @@index([clientId])
  @@index([leadId])
  @@index([roofEstimateId])
  @@index([validUntil])
}

model QuoteItem {
  id            String    @id @default(uuid())
  
  description   String
  quantity      Decimal   @default(1) @db.Decimal(10, 2)
  unitPrice     Decimal   @db.Decimal(15, 2)
  total         Decimal   @db.Decimal(15, 2)
  
  // Sort order
  sortOrder     Int       @default(0)
  
  // Parent Quote
  quoteId       String
  quote         Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

// ============================================================================
// CONTRACTS MODULE
// ============================================================================

enum ContractStatus {
  DRAFT
  SENT
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

model Contract {
  id                String          @id @default(uuid())
  
  // Contract Number (auto-generated like invoices)
  contractNumber    String
  title             String
  description       String?         @db.Text
  
  // Status
  status            ContractStatus  @default(DRAFT)
  
  // Linked entities
  clientId          String
  client            Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  quoteId           String?         // Optional link to accepted quote
  projectId         String?         // Optional link to project
  
  // Financial
  value             Decimal         @db.Decimal(15, 2)
  currency          String          @default("CAD")
  
  // Dates
  startDate         DateTime
  endDate           DateTime
  signedAt          DateTime?
  
  // Terms & Content
  terms             String?         @db.Text
  notes             String?         @db.Text
  
  // Created by
  createdById       String?
  createdBy         Employee?       @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([tenantId, contractNumber])
  @@index([tenantId])
  @@index([status])
  @@index([clientId])
  @@index([startDate])
  @@index([endDate])
}