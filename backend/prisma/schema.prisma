// ============================================================================
// TENANT & USER MANAGEMENT
// ============================================================================

model Tenant {
  id                    String        @id @default(uuid())
  name                  String
  slug                  String        @unique
  domain                String?       @unique
  status                TenantStatus  @default(TRIAL)
  logo                  String?
  
  // Settings stored as JSON for flexibility
  settings              Json          @default("{}")
  
  // Storage quotas
  fileStorageQuota      BigInt        @default(5368709120) // 5GB
  fileStorageUsed       BigInt        @default(0)
  emailStorageQuota     BigInt        @default(1073741824) // 1GB
  emailStorageUsed      BigInt        @default(0)
  
  // Subscription info (basic - extend as needed)
  subscriptionTier      String        @default("free")
  subscriptionExpiresAt DateTime?
  
  // Onboarding lifecycle flag — set TRUE only after seedTenant() completes
  onboardingCompleted   Boolean       @default(false)
  
  // Timestamps
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  // Relations
  users                 User[]
  employees             Employee[]
  roles                 Role[]
  leads                 Lead[]
  clients               Client[]
  contacts              Contact[]
  clientGroups          ClientGroup[]
  applications          Application[]
  tasks                 Task[]
  projects              Project[]
  calendarEvents        CalendarEvent[]
  files                 File[]
  folders               Folder[]
  invoices              Invoice[]
  expenses              Expense[]
  expenseBudgets        ExpenseBudget[]
  bookings              Booking[]
  services              Service[]
  products              Product[]
  productCategories     ProductCategory[]
  orders                Order[]
  emails                Email[]
  communicationLogs     CommunicationLog[]
  emailLabels           EmailLabel[]
  chatRooms             ChatRoom[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  leadSources           LeadSource[]
  tenantSettings        TenantSettings?
  tags                  Tag[]
  roofEstimates         RoofEstimate[]
  roofEstimateSettings  RoofEstimateSettings?
  roofData              RoofData[]
  solarRoofData         SolarRoofData[]
  roofMaterials         RoofMaterial[]
  roofTakeoffs          RoofTakeoff[]
  roofLaborRates        RoofLaborRate[]
  payments              InvoicePayment[]
  quotes                Quote[]
  contracts             Contract[]
  leadInspections       LeadInspection[]
  leadInsuranceClaims   LeadInsuranceClaim[]
  leadContactedDetails  LeadContactedDetails[]
  subscription          Subscription?
  userAccesses          UserAccess[]
  timeEntries           TimeEntry[]
  jobNotes              JobNote[]
  crewNotifications     CrewNotification[]
  checklistTemplates    ChecklistTemplate[]
  checklistSubmissions  ChecklistSubmission[]
  jobPhotos             JobPhoto[]
  jobMessages           JobMessage[]
  equipment             Equipment[]
  materialRequests      MaterialRequest[]
  incidentReports       IncidentReport[]
  leaveRequests         LeaveRequest[]
  employeeDocuments     EmployeeDocument[]
  jobCompletions        JobCompletion[]
  proposals             Proposal[]
  signedContracts       SignedContract[]
  constructionEstimates ConstructionEstimate[]
  supportTickets        SupportTicket[]
  wallets               Wallet[]

  @@index([status])
  @@index([slug])
}

model User {
  id                    String        @id @default(uuid())
  email                 String        @unique
  passwordHash          String
  firstName             String
  lastName              String
  avatar                String?
  phone                 String?
  status                UserStatus    @default(PENDING_VERIFICATION)
  emailVerified         Boolean       @default(false)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  passwordChangedAt     DateTime?
  
  // Preferences stored as JSON
  preferences           Json          @default("{}")
  
  // Timestamps
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  // Tenant relation (optional - user can exist without tenant initially)
  tenantId              String?
  tenant                Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  
  // Relations
  refreshTokens         RefreshToken[]
  employees             Employee[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  userPreferences       UserPreferences?
  mailboxEmails         Email[]        @relation("MailboxOwnerUser")

  @@index([email])
  @@index([tenantId])
  @@index([status])
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  replacedBy  String?   // For token rotation
  userAgent   String?
  ipAddress   String?

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Employee {
  id                    String        @id @default(uuid())
  employeeNumber        String?       // Optional employee ID/number
  department            String?
  position              String?
  hireDate              DateTime?
  isActive              Boolean       @default(true)
  employmentStatus      String        @default("active")
  employmentType        String        @default("full-time")
  salary                Float?
  profileData           Json          @default("{}")
  
  // Tenant relation (REQUIRED for employees)
  tenantId              String
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // User relation
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Role relation
  roleId                String
  role                  Role          @relation(fields: [roleId], references: [id])
  
  // Timestamps
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  // Relations
  assignedLeads         Lead[]        @relation("AssignedToEmployee")
  createdLeads          Lead[]        @relation("CreatedByEmployee")
  assignedClients       Client[]      @relation("AssignedToEmployee")
  assignedTasks         Task[]        @relation("AssignedToEmployee")
  createdTasks          Task[]        @relation("CreatedByEmployee")
  projectMembers        ProjectMember[]
  createdInvoices       Invoice[]     @relation("CreatedByEmployee")
  createdExpenses       Expense[]     @relation("CreatedByEmployee")
  approvedExpenses      Expense[]     @relation("ApprovedByEmployee")
  assignedBookings      Booking[]
  sentEmails            Email[]       @relation("SentByEmployee")
  chatParticipations    ChatParticipant[]
  calendarEvents        CalendarEvent[] @relation("CreatedByEmployee")
  eventAttendees        CalendarEventAttendee[]
  createdQuotes         Quote[]         @relation("CreatedByEmployee")
  createdContracts      Contract[]      @relation("ContractCreatedBy")
  timeEntries           TimeEntry[]
  jobNotes              JobNote[]
  crewNotifications     CrewNotification[]
  checklistSubmissions  ChecklistSubmission[]
  locationPings         LocationPing[]
  jobPhotos             JobPhoto[]
  sentMessages          JobMessage[]
  assignedEquipment     Equipment[]
  materialRequests      MaterialRequest[]
  incidentReports       IncidentReport[]
  leaveRequests         LeaveRequest[]       @relation("LeaveRequests")
  reviewedLeaves        LeaveRequest[]       @relation("LeaveReviewedBy")
  availability          Availability[]
  employeeDocuments     EmployeeDocument[]
  jobCompletions        JobCompletion[]
  createdProposals      Proposal[]       @relation("ProposalCreatedBy")
  userAccesses          UserAccess[]

  @@unique([tenantId, userId])
  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([isActive])
}

// ============================================================================
// RBAC - ROLES & PERMISSIONS
// ============================================================================

model Role {
  id              String        @id @default(uuid())
  name            String
  description     String?
  isSystemRole    Boolean       @default(false) // Owner, Admin, etc. cannot be deleted
  isDefault       Boolean       @default(false) // Default role for new employees
  
  // Tenant relation
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  employees       Employee[]
  permissions     RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isSystemRole])
}

model Permission {
  id              String        @id @default(uuid())
  code            String        @unique // e.g., "leads.view", "leads.create"
  name            String
  description     String?
  module          String        // e.g., "leads", "clients", "invoices"
  action          String        // e.g., "view", "create", "update", "delete"
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  roles           RolePermission[]

  @@unique([module, action])
  @@index([module])
  @@index([code])
}

model RolePermission {
  id              String      @id @default(uuid())
  
  roleId          String
  role            Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  permissionId    String
  permission      Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  // Optional constraints (for future use)
  constraints     Json?       // e.g., {"ownOnly": true}
  
  createdAt       DateTime    @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ============================================================================
// DATA-LEVEL ACCESS CONTROL
// ============================================================================

model UserAccess {
  id          String    @id @default(uuid())

  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  clientId    String?
  client      Client?   @relation("UserAccessClient", fields: [clientId], references: [id], onDelete: Cascade)

  projectId   String?
  project     Project?  @relation("UserAccessProject", fields: [projectId], references: [id], onDelete: Cascade)

  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@unique([employeeId, clientId, projectId])
  @@index([employeeId])
  @@index([tenantId])
  @@index([clientId])
  @@index([projectId])
}

// ============================================================================
// LEADS MODULE
// ============================================================================

model LeadSource {
  id              String              @id @default(uuid())
  name            String
  slug            String?
  description     String?
  isActive        Boolean             @default(true)

  // Type & Category
  sourceType      LeadSourceType      @default(WEBSITE)
  category        LeadSourceCategory  @default(DIGITAL)
  icon            String?             // icon name for UI
  color           String?             // hex color for UI

  // Integration
  integrationStatus IntegrationStatus @default(DISCONNECTED)
  integrationConfig Json?             // platform-specific config (page IDs, form IDs, etc.)
  webhookUrl        String?           // auto-generated webhook URL
  webhookSecret     String?           // for signature verification
  apiEndpoint       String?           // optional custom endpoint

  // OAuth (encrypted at app level)
  accessToken           String?       @db.Text
  refreshToken          String?       @db.Text
  tokenExpiresAt        DateTime?
  tokenScopes           String[]      @default([])
  externalAccountId     String?
  externalAccountName   String?

  // Cost Tracking
  costPerLead     Decimal?            @db.Decimal(10, 2)
  monthlyBudget   Decimal?            @db.Decimal(10, 2)
  autoSyncCost    Boolean             @default(false)

  // Assignment Rules
  autoAssign        Boolean           @default(false)
  assignmentMethod  AssignmentMethod  @default(MANUAL_ASSIGN)
  assignedUserId    String?
  assignedTeamId    String?
  territoryRules    Json?             // zip code mapping, etc.

  // Automation
  sendWelcomeEmail        Boolean     @default(false)
  welcomeEmailTemplateId  String?
  sendWelcomeSms          Boolean     @default(false)
  welcomeSmsTemplateId    String?
  createFollowupTask      Boolean     @default(true)
  followupDelayMinutes    Int         @default(30)
  notifyAssignee          Boolean     @default(true)
  notificationChannels    String[]    @default(["email", "in_app"])

  // Field Mapping
  fieldMapping     Json?              // maps external fields -> CRM fields
  defaultValues    Json?              // default values for unmapped fields

  // Cached Statistics
  totalLeads       Int                @default(0)
  convertedLeads   Int                @default(0)
  totalRevenue     Decimal?           @db.Decimal(15, 2) @default(0)
  lastLeadAt       DateTime?
  statsUpdatedAt   DateTime?

  // Source Status
  status           LeadSourceStatus   @default(ACTIVE)
  lastSyncAt       DateTime?
  lastError        String?            @db.Text
  lastErrorAt      DateTime?
  errorCount       Int                @default(0)

  // Tenant & Timestamps
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  leads           Lead[]
  credentials     LeadSourceCredential[]
  webhooks        LeadSourceWebhook[]
  logs            LeadSourceLog[]

  @@unique([tenantId, name])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([isActive])
  @@index([sourceType])
  @@index([status])
  @@index([integrationStatus])
}

model LeadSourceCredential {
  id              String      @id @default(uuid())
  leadSourceId    String
  leadSource      LeadSource  @relation(fields: [leadSourceId], references: [id], onDelete: Cascade)

  credentialKey   String      // e.g. 'api_key', 'client_id', 'client_secret'
  credentialValue String      @db.Text  // encrypted with AES-256
  credentialType  String      @default("api_key") // api_key, oauth_token, secret, password
  expiresAt       DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([leadSourceId, credentialKey])
  @@index([leadSourceId])
}

model LeadSourceWebhook {
  id                  String      @id @default(uuid())
  leadSourceId        String
  leadSource          LeadSource  @relation(fields: [leadSourceId], references: [id], onDelete: Cascade)

  externalWebhookId   String?     // webhook ID from external platform
  webhookUrl          String
  webhookSecret       String
  verifyToken         String?     // for verification challenges
  subscribedEvents    String[]    @default([])

  status              String      @default("pending") // pending, active, failed, disabled
  failureCount        Int         @default(0)
  lastTriggeredAt     DateTime?
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  lastFailureReason   String?     @db.Text

  createdAt           DateTime    @default(now())

  @@index([leadSourceId])
  @@index([status])
}

model LeadSourceLog {
  id              String      @id @default(uuid())
  leadSourceId    String
  leadSource      LeadSource  @relation(fields: [leadSourceId], references: [id], onDelete: Cascade)

  eventType       String      // webhook_received, lead_created, lead_duplicate, connection_test, error, etc.
  status          String      // success, failed, pending, skipped
  direction       String      @default("inbound") // inbound, outbound

  requestPayload  Json?       // sanitized — no sensitive data
  responsePayload Json?
  errorMessage    String?     @db.Text
  processingTimeMs Int?

  leadId          String?     // if a lead was created
  ipAddress       String?
  userAgent       String?

  createdAt       DateTime    @default(now())

  @@index([leadSourceId, createdAt(sort: Desc)])
  @@index([eventType])
  @@index([status])
}

model Lead {
  id                String          @id @default(uuid())
  leadNumber        String?                   // Auto-generated: LD-YYYY-0001
  
  // Basic Info
  firstName         String
  lastName          String
  email             String?
  phone             String?
  location          String?
  
  // Company Info
  companyName       String?
  jobTitle          String?
  website           String?
  
  // Lead Classification
  status            LeadStatus          @default(NEW)
  temperature       LeadTemperature     @default(WARM)
  lifecycleStage    LeadLifecycleStage  @default(LEAD)
  potentialValue    Decimal?            @db.Decimal(15, 2)
  
  // Source
  leadSourceId      String?
  leadSource        LeadSource?     @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  
  // Assignment
  assignedToId      String?
  assignedTo        Employee?       @relation("AssignedToEmployee", fields: [assignedToId], references: [id], onDelete: SetNull)
  
  // Notes
  notes             String?         @db.Text
  
  // Conversion tracking
  convertedAt       DateTime?
  convertedToClientId String?
  
  // ── Stage 1: Property Info ─────────────────────────────────────────────
  propertyAddress       String?
  city                  String?
  state                 String?
  zipCode               String?
  propertyType          String?             // Residential, Commercial, Multi-Family

  // ── Stage 1: Service Request ───────────────────────────────────────────
  serviceType           String?             // Roof Replacement, Repair, Storm/Hail, etc.
  isInsuranceClaim      String?             // Yes, No, Not Sure
  urgencyLevel          String?             // Emergency, ASAP, Within weeks, Planning
  preferredContactMethod String?            // Phone Call, Text, Email
  bestTimeToContact     String?             // Morning, Afternoon, Evening, Anytime
  issueDescription      String?   @db.Text

  // ── Stage 1: UTM / Auto-captured ───────────────────────────────────────
  leadSourceUTM         String?
  leadCampaignUTM       String?
  leadMediumUTM         String?
  landingPageURL        String?
  ipAddress             String?
  deviceType            String?
  browserType           String?

  // ── Stage 2: Verification ──────────────────────────────────────────────
  confirmedName         Boolean   @default(false)
  confirmedPhone        Boolean   @default(false)
  confirmedEmail        Boolean   @default(false)
  confirmedAddress      Boolean   @default(false)
  secondaryPhone        String?
  spouseCoOwnerName     String?

  // ── Stage 2: Ownership Qualification ───────────────────────────────────
  isHomeowner           String?             // Yes, No, Tenant
  isDecisionMaker       String?             // Yes, No, Need Spouse Approval
  ownershipType         String?             // Owner-Occupied, Rental, Investment

  // ── Stage 2: Roof Details ──────────────────────────────────────────────
  roofAge               String?             // 0-5, 5-10, 10-15, 15-20, 20+, Unknown
  currentRoofMaterial   String?             // Asphalt, Metal, Tile, Flat, Wood, Slate, Unknown
  numberOfStories       String?             // 1, 2, 3+
  knownDamageType       Json?               // array: Leak, Missing Shingles, Storm, etc.
  damageOccurrenceDate  String?
  previousRoofWork      String?             // Yes, No, Unknown
  previousRoofWorkDetails String?

  // ── Stage 2: Insurance Info (conditional) ──────────────────────────────
  insuranceCompanyName  String?
  hasClaimBeenFiled     String?             // Yes, No, Planning To
  claimNumber           String?
  adjusterAssigned      String?             // Yes, No, Not Yet
  adjusterName          String?
  adjusterPhone         String?
  adjusterEmail         String?
  adjusterMeetingDate   DateTime?

  // ── Stage 2: Budget & Timeline ─────────────────────────────────────────
  budgetRange           String?             // Under $5k, $5-10k, $10-20k, $20k+, Insurance, Not Sure
  workTimeline          String?             // ASAP, 1-2 Weeks, Within 1 Month, etc.
  financingNeeded       String?             // Yes, No, Maybe
  gettingOtherQuotes    String?             // Yes, No
  numberOfOtherQuotes   Int?
  topPriority           String?             // Price, Quality, Speed, Warranty, Reputation

  // ── Stage 2: HOA ───────────────────────────────────────────────────────
  isHOA                 String?             // Yes, No, Not Sure
  hoaRestrictions       String?   @db.Text

  // ── Stage 2: Sales Assessment ──────────────────────────────────────────
  leadScore             Int?                // 1-10
  estimationMethod      EstimationMethod?
  disqualifiedReason    String?
  nextStep              String?             // Schedule Inspection, Send Info, Follow Up, Dead Lead
  followUpDateTime      DateTime?
  inspectionAppointmentDate DateTime?
  qualificationCallNotes String?  @db.Text

  // ── Closure / Inactive State Fields ────────────────────────────────────
  closureReason         String?   @db.Text    // Required for LOST, DUPLICATE; optional for other inactive states
  duplicateOfLeadId     String?               // Links to original lead when status = DUPLICATE
  closedAt              DateTime?             // When the lead was moved to a terminal/inactive state
  reactivateAt          DateTime?             // For FUTURE_FOLLOW_UP: date-based reactivation

  // Tenant relation
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Created by
  createdById       String?
  createdBy         Employee?       @relation("CreatedByEmployee", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  // Relations
  tags              LeadTag[]
  calendarEvents    CalendarEvent[]
  activities        LeadActivity[]
  quotes            Quote[]
  projects          Project[]
  files             File[]
  emails            Email[]
  communicationLogs CommunicationLog[]
  contactedDetails  LeadContactedDetails?
  inspections       LeadInspection[]
  insuranceClaims   LeadInsuranceClaim[]
  roofEstimates     RoofEstimate[]
  proposals         Proposal[]

  @@index([tenantId])
  @@index([status])
  @@index([temperature])
  @@index([assignedToId])
  @@index([leadSourceId])
  @@index([createdAt])
  @@index([serviceType])
  @@index([isInsuranceClaim])
  @@index([zipCode])
  @@unique([tenantId, leadNumber])
}

model LeadContactedDetails {
  id                  String   @id @default(uuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId              String   @unique
  lead                Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Property info
  propertyType        String
  numberOfStories     String
  approxRoofAge       String
  currentRoofMaterial String?

  // Problem / need
  mainIssue           String[]
  urgencyLevel        String
  issueStartTimeline  String

  // Insurance (conditional)
  isInsuranceClaim    Boolean
  insuranceCompany    String?
  claimFiled          String?
  dateOfDamage        DateTime?
  claimNumber         String?

  // Decision & timeline
  decisionMaker       String
  decisionTimeline    String
  gettingOtherQuotes  Boolean?

  // Sales notes
  contactNotes        String
  leadTemperature     String
  estimatedDealValue  Decimal  @db.Decimal(12, 2)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, leadId])
}

model LeadInspection {
  id                    String   @id @default(uuid())
  leadId                String
  lead                  Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ── General ─────────────────────────────────────────────────
  inspectionDate        DateTime?
  inspectorName         String?
  inspectionType        String?          // Initial, Re-inspect, Insurance, Final
  weatherConditions     String?
  accessMethod          String?          // Ladder, Drone, Walk-on, Binoculars
  overallCondition      String?          // Poor, Fair, Good, Excellent

  // ── Roof Assessment (~25) ───────────────────────────────────
  roofStyle             String?          // Gable, Hip, Flat, Mansard, Gambrel, Shed
  roofPitch             String?          // Low(2-4), Medium(5-7), Steep(8-12)
  totalSquares          Decimal?  @db.Decimal(10,2)
  ridgeLength           Decimal?  @db.Decimal(10,2)
  valleyLength          Decimal?  @db.Decimal(10,2)
  eaveLength            Decimal?  @db.Decimal(10,2)
  rakeLength            Decimal?  @db.Decimal(10,2)
  numberOfLayers        Int?
  deckingType           String?          // Plywood, OSB, 1x6, Skip
  deckingCondition      String?          // Good, Needs Repair, Needs Replace
  underlaymentType      String?          // Felt, Synthetic, Ice&Water
  ventilationType       String?          // Ridge, Box, Turbine, Power, Soffit
  ventilationCount      Int?
  flashingCondition     String?          // Good, Repair, Replace
  gutterCondition       String?          // Good, Repair, Replace, None
  skylightCount         Int?
  skylightCondition     String?
  chimneyPresent        Boolean?  @default(false)
  chimneyCondition      String?
  soffitFasciaCondition String?          // Good, Repair, Replace
  dripEdgePresent       Boolean?  @default(false)
  dripEdgeCondition     String?
  iceWaterShieldPresent Boolean?  @default(false)

  // ── Damage Assessment (~10) ─────────────────────────────────
  stormDamageFound      Boolean?  @default(false)
  windDamageDetails     String?   @db.Text
  hailDamageDetails     String?   @db.Text
  hailSizeFound         String?          // Pea, Marble, Quarter, Golf Ball, Baseball
  testSquareResults     String?   @db.Text
  interiorDamageFound   Boolean?  @default(false)
  interiorDamageDetails String?   @db.Text
  photosTakenCount      Int?
  overallDamageRating   String?          // None, Minor, Moderate, Severe, Total Loss

  // ── Material Selections (~10) ───────────────────────────────
  proposedMaterial      String?          // Asphalt, Metal, Tile, Flat, etc.
  shingleBrand          String?
  shingleLine           String?
  shingleColor          String?
  underlaymentChoice    String?
  ridgeCapType          String?
  ventilationPlan       String?
  dripEdgeColor         String?
  warrantyType          String?          // Manufacturer, Workmanship, Extended
  warrantyYears         Int?

  // ── Estimate & Pricing (~16) ────────────────────────────────
  materialCost          Decimal?  @db.Decimal(15,2)
  laborCost             Decimal?  @db.Decimal(15,2)
  tearOffCost           Decimal?  @db.Decimal(15,2)
  permitCost            Decimal?  @db.Decimal(15,2)
  dumpsterCost          Decimal?  @db.Decimal(15,2)
  miscCost              Decimal?  @db.Decimal(15,2)
  subtotal              Decimal?  @db.Decimal(15,2)
  overheadPercent       Decimal?  @db.Decimal(5,2)
  profitPercent         Decimal?  @db.Decimal(5,2)
  totalEstimate         Decimal?  @db.Decimal(15,2)
  customerPrice         Decimal?  @db.Decimal(15,2)
  depositRequired       Decimal?  @db.Decimal(15,2)
  depositCollected      Boolean?  @default(false)
  paymentMethod         String?          // Cash, Check, Card, Financing, Insurance
  estimateStatus        String?          // Draft, Sent, Accepted, Rejected, Revised

  // ── Scheduling & Logistics (~10) ────────────────────────────
  tentativeStartDate    DateTime?
  estimatedDuration     String?          // 1 Day, 2-3 Days, 1 Week, etc.
  crewSize              Int?
  crewLeadName          String?
  materialsOrdered      Boolean?  @default(false)
  materialsDeliveryDate DateTime?
  permitPulled          Boolean?  @default(false)
  permitNumber          String?
  dumpsterOrdered       Boolean?  @default(false)
  dumpsterDeliveryDate  DateTime?

  // ── Notes ───────────────────────────────────────────────────
  inspectorNotes        String?   @db.Text
  customerFeedback      String?   @db.Text
  internalNotes         String?   @db.Text

  // ── Timestamps ──────────────────────────────────────────────
  createdById           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([leadId])
  @@index([tenantId])
  @@index([inspectionDate])
  @@index([estimateStatus])
}

model LeadInsuranceClaim {
  id                        String   @id @default(uuid())
  leadId                    String
  lead                      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenantId                  String
  tenant                    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  claimNumber               String?
  insuranceEstimateACV      Decimal?  @db.Decimal(15,2)
  recoverableDepreciation   Decimal?  @db.Decimal(15,2)
  fullRCVAmount             Decimal?  @db.Decimal(15,2)
  deductibleAmount          Decimal?  @db.Decimal(15,2)
  supplementNeeded          Boolean?  @default(false)
  supplementAmount          Decimal?  @db.Decimal(15,2)
  supplementStatus          String?          // Pending, Submitted, Approved, Denied
  mortgageCompanyName       String?
  mortgageCompanyAddress    String?
  mortgageLoanNumber        String?
  claimStatus               String?          // Open, In Review, Approved, Denied, Supplement
  claimNotes                String?   @db.Text

  createdById               String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([leadId])
  @@index([tenantId])
  @@index([claimStatus])
}

model LeadTag {
  id        String   @id @default(uuid())
  
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
  @@index([leadId])
  @@index([tagId])
}

model LeadActivity {
  id          String    @id @default(uuid())
  type        String    // e.g., "note", "email", "call", "meeting", "status_change"
  title       String
  description String?   @db.Text
  metadata    Json?     // Additional data based on type
  
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================================
// CLIENTS MODULE
// ============================================================================

model Client {
  id                      String        @id @default(uuid())
  
  // 1️⃣ Basic Information
  clientLogo              String?
  clientName              String
  companyName             String?
  clientType              ClientType    @default(BUSINESS)
  primaryEmail            String
  primaryPhone            String
  status                  ClientStatus          @default(ACTIVE)
  lifecycleStage          ClientLifecycleStage   @default(NEW_CUSTOMER)
  assignedOwnerId         String?
  assignedOwner           Employee?     @relation("AssignedToEmployee", fields: [assignedOwnerId], references: [id], onDelete: SetNull)
  
  // 2️⃣ Business & Tax Details
  gstHstNumber            String?
  pstQstNumber            String?
  businessStructure       String?
  corpRegistrationNumber  String?
  
  // 3️⃣ Billing Address
  streetAddress           String?
  suite                   String?
  city                    String?
  province                String?
  postalCode              String?
  country                 String?
  
  // 4️⃣ Internal Notes
  internalNotes           String?       @db.Text
  
  // 5️⃣ Primary Contact
  contactName             String?
  position                String?
  directPhone             String?
  
  // 6️⃣ Financial Settings
  creditLimit             Decimal?      @db.Decimal(15, 2)
  paymentTerms            String?
  currency                String        @default("CAD")
  
  // 7️⃣ Categorization
  leadSource              String?
  clientCategory          String?
  tags                    Json          @default("[]")

  // 8️⃣ Property Information
  propertyType            String?             // Residential, Commercial, Multi-Family
  numberOfStories         String?             // 1, 2, 3+

  // 9️⃣ Service Details
  serviceType             String?             // Roof Replacement, Repair, Storm/Hail, etc.
  preferredContactMethod  String?             // Phone Call, Text, Email
  bestTimeToContact       String?             // Morning, Afternoon, Evening, Anytime

  // 🔟 Roof Details
  currentRoofMaterial     String?             // Asphalt, Metal, Tile, Flat, Wood, Slate, Unknown
  roofAge                 String?             // 0-5, 5-10, 10-15, 15-20, 20+, Unknown

  // 1️⃣1️⃣ Insurance Info
  insuranceCompanyName    String?
  isInsuranceClaim        String?             // Yes, No, Not Sure

  // 1️⃣2️⃣ Ownership & HOA
  isHomeowner             String?             // Yes, No, Tenant
  isHOA                   String?             // Yes, No, Not Sure
  hoaRestrictions         String?   @db.Text

  // 1️⃣3️⃣ Secondary Contact
  secondaryPhone          String?
  spouseCoOwnerName       String?

  // 1️⃣4️⃣ Extended Roof Details
  roofSize                String?             // Sq ft from measurement tools
  roofPitch               String?             // e.g., 6/12 pitch, 2 layers

  // 1️⃣5️⃣ Lead Tracking
  budgetRange             String?             // $5k-10k, $10k-20k, etc.
  urgencyLevel            String?             // High, Medium, Low

  // 1️⃣6️⃣ Project / Warranty
  warrantyExpiration      DateTime?           // Manufacturer + labor warranty

  // 1️⃣7️⃣ Communication Preferences
  doNotContact            Boolean   @default(false)
  nextFollowUp            DateTime?
  language                String?             // e.g., English, Spanish, French

  // Tracking
  totalRevenue            Decimal       @default(0) @db.Decimal(15, 2)
  
  // Tenant relation
  tenantId                String
  tenant                  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  
  // Relations
  contacts                Contact[]
  groups                  ClientGroupMember[]
  projects                Project[]
  invoices                Invoice[]
  quotes                  Quote[]
  orders                  Order[]
  bookings                Booking[]
  tasks                   Task[]
  files                   File[]
  emails                  Email[]
  payments                InvoicePayment[]
  roofEstimates           RoofEstimate[]
  roofData                RoofData[]
  calendarEvents          CalendarEvent[]
  contracts               Contract[]
  userAccesses            UserAccess[]   @relation("UserAccessClient")

  @@index([tenantId])
  @@index([status])
  @@index([clientType])
  @@index([assignedOwnerId])
  @@index([primaryEmail])
}

// ============================================================================
// CONTACTS MODULE
// ============================================================================

model Contact {
  id                String        @id @default(uuid())
  
  // Contact Info
  contactName       String
  type              ContactType   @default(CLIENT)
  jobTitle          String?
  department        String?
  email             String
  officePhone       String?
  mobilePhone       String?
  linkedInUrl       String?
  
  // Flags
  isPrimaryContact  Boolean       @default(false)
  
  // Client relation (optional - can be standalone contact)
  companyId         String?
  company           Client?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([tenantId])
  @@index([companyId])
  @@index([isPrimaryContact])
  @@index([email])
  @@index([type])

  // Relations
  emails                Email[]
}

// ============================================================================
// CLIENT GROUPS MODULE
// ============================================================================

model ClientGroup {
  id                  String      @id @default(uuid())
  name                String
  description         String?
  color               String?     // For UI display
  
  // Auto-update rules (stored as JSON)
  autoUpdateEnabled   Boolean     @default(false)
  autoUpdateRules     Json?       // e.g., {"industry": "Technology", "status": "ACTIVE"}
  
  // Tenant relation
  tenantId            String
  tenant              Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  members             ClientGroupMember[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ClientGroupMember {
  id            String        @id @default(uuid())
  
  groupId       String
  group         ClientGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  addedAt       DateTime      @default(now())
  addedManually Boolean       @default(true) // vs auto-added by rules

  @@unique([groupId, clientId])
  @@index([groupId])
  @@index([clientId])
}

// ============================================================================
// APPLICATIONS MODULE
// ============================================================================

model Application {
  id              String            @id @default(uuid())
  
  // Application Info
  referenceNumber String
  title           String
  description     String?           @db.Text
  
  // Status & Lifecycle
  status          ApplicationStatus @default(DRAFT)
  submittedAt     DateTime?
  reviewedAt      DateTime?
  completedAt     DateTime?
  
  // Form Data (flexible JSON for different application types)
  formData        Json              @default("{}")
  
  // Attachments tracked via File model with applicationId
  
  // Notes
  internalNotes   String?           @db.Text
  
  // Tenant relation
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relations
  files           File[]

  @@unique([tenantId, referenceNumber])
  @@index([tenantId])
  @@index([status])
  @@index([referenceNumber])
}

// ============================================================================
// TASKS MODULE
// ============================================================================

model Task {
  id              String        @id @default(uuid())
  
  // Task Info
  title           String
  description     String?       @db.Text
  
  // Status & Priority
  status          TaskStatus    @default(TODO)
  priority        TaskPriority  @default(MEDIUM)
  
  // Dates
  dueDate         DateTime?
  startDate       DateTime?
  completedAt     DateTime?
  
  // Estimation (in minutes)
  estimatedTime   Int?
  actualTime      Int?
  
  // Assignment
  assignedToId    String?
  assignedTo      Employee?     @relation("AssignedToEmployee", fields: [assignedToId], references: [id], onDelete: SetNull)
  
  // Created by
  createdById     String?
  createdBy       Employee?     @relation("CreatedByEmployee", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Project relation (optional)
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  // Client relation (optional)
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  // Tenant relation
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  tags            TaskTag[]
  subtasks        Task[]        @relation("TaskSubtasks")
  parentTask      Task?         @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  parentTaskId    String?
  timeEntries     TimeEntry[]

  @@index([tenantId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([projectId])
  @@index([dueDate])
}

model TaskTag {
  id        String   @id @default(uuid())
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
}

// ============================================================================
// PROJECTS MODULE
// ============================================================================

model Project {
  id              String          @id @default(uuid())
  
  // Project Info
  name            String
  description     String?         @db.Text
  code            String?         // Project code/identifier
  projectNumber   String?         // Auto-generated: PRJ-2026-0001
  internalNotes   String?         @db.Text
  tags            String[]        @default([])
  customFields    Json?           @default("{}")
  deletedAt       DateTime?
  
  // Status
  status          ProjectStatus   @default(PLANNING)
  priority        ProjectPriority @default(NORMAL)
  projectType     ProjectType     @default(REPLACEMENT)
  propertyType    PropertyType    @default(RESIDENTIAL)
  
  // Pipeline stage
  stageId         String?
  stage           ProjectStage?   @relation(fields: [stageId], references: [id], onDelete: SetNull)
  
  // Dates
  startDate       DateTime?
  endDate         DateTime?
  actualEndDate   DateTime?
  estimatedStartDate DateTime?
  actualStartDate DateTime?
  estimatedEndDate DateTime?
  estimatedDuration Int?
  actualDuration  Int?
  
  // Budget
  budget          Decimal?        @db.Decimal(15, 2)
  currency        Currency        @default(USD)
  contractValue   Decimal?        @db.Decimal(12, 2)
  estimatedCost   Decimal?        @db.Decimal(12, 2)
  actualCost      Decimal?        @db.Decimal(12, 2)
  grossProfit     Decimal?        @db.Decimal(12, 2)
  profitMargin    Decimal?        @db.Decimal(5, 2)
  deductible      Decimal?        @db.Decimal(10, 2)
